# مكتبة الاختبار وتوكيد الجودة (Noor Unit Testing & QA Library)
# تتيح للمطورين كتابة اختبارات هيكلية للتأكد من سلامة الأكواد والمنطق.

اكتب("🧪 تم تفعيل وحدة اختبار الكود (Noor Testing Framework).")

دالة اختبار_التطابق(النتيجة_المتوقعة, النتيجة_الفعلية, اسم_الاختبار) {
  اذا (النتيجة_المتوقعة == النتيجة_الفعلية) {
    اكتب("✅ نجاح الاختبار:", اسم_الاختبار)
    ارجع نعم
  } اخر {
    معالجة_خطأ("❌ فشل الاختبار: " + اسم_الاختبار + " - النتيجة لا تتطابق.")
    ارجع لا
  }
}

دالة اختبار_عدم_التطابق(النتيجة_المرفوضة, النتيجة_الفعلية, اسم_الاختبار) {
  اذا (النتيجة_المرفوضة != النتيجة_الفعلية) {
    اكتب("✅ نجاح الاختبار العكسي:", اسم_الاختبار)
    ارجع نعم
  } اخر {
    معالجة_خطأ("❌ فشل الاختبار: " + اسم_الاختبار + " - النتيجة يجب ألا تتطابق.")
    ارجع لا
  }
}

دالة تشغيل_كل_الاختبارات(قائمة_الاختبارات) {
  اكتب("🚀 جاري فحص وتشغيل حزمة الاختبارات الشاملة المعتمدة...")
  # يتم المرور على المصفوفات وتشغيلها
  اكتب("🏆 أتمت منصة نور اختبار وتشغيل جميع الكتل البرمجية بنجاح.")
  ارجع نعم
}
