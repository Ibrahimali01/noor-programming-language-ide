// ملف شامل لتجربة الإضافات الحديدية السيادية المستقلة لنور
اكتب("=====================================================")
اكتب("🔥 اختبار ترسانة مكاتب الحزمة الأساسية السيادية لنور 🔥")
اكتب("=====================================================")

تحميل_مكتبة("std_datetime")
تحميل_مكتبة("std_system_info")
تحميل_مكتبة("std_http_client")
تحميل_مكتبة("std_terminal")
تحميل_مكتبة("std_base64")
تحميل_مكتبة("std_hash")

اكتب(" ")
طباعة_ملونة("1. معلومات نظام التشغيل الحي المباشر:", "سماوي")
اكتب("   - النظام المستخدم:", اسم_النظام())
اكتب("   - معمارية المعالج الصدفي:", العمارة_المعمارية())
اكتب("   - مدة التشغيل للنواة الحية:", مدة_التشغيل())
اكتب("   - المستخدم النشط بالصلاحيات:", المستخدم_الحالي())

اكتب(" ")
طباعة_ملونة("2. التوقيت الزمني الدقيق من ساعة العتاد:", "أخضر")
اكتب("   - تاريخ اليوم المعياري:", تاريخ_اليوم())
اكتب("   - الوقت الحالي:", الوقت_الحالي())
اكتب("   - الطابع الزمني العالمي (Timestamp):", الطابع_الزمني())

اكتب(" ")
طباعة_ملونة("3. محرك الهاش وتشفير العملات المعماة:", "أصفر")
انشئ كود_سري = "كود_سيادي_فائق_السرية"
اكتب("   - النص الأصلي للحقن:", كود_سري)
اكتب("   - تشفير MD5 الأحادي:", هاش_md5(كود_سري))
اكتب("   - تشفير SHA256 العسكري:", هاش_sha256(كود_سري))
اكتب("   - ترميز BASE64 للبصمات الشبكية:", ترميز_باز64(كود_سري))

اكتب(" ")
طباعة_ملونة("4. إنشاء اتصال شبكي حقيقي بخادم خارجي (HTTP/s):", "بنفسجي")
اكتب("   - جاري التحقق من حالة خادم google.com ...")
انشئ ترويسات = جلب_ترويسات("https://google.com")
اكتب("   [نتيجة الاتصال بالخادم الحي]:")
اكتب(قص_النص(ترويسات, 0, 100) + "...")

اكتب(" ")
طباعة_ملونة("✅ تمت تجربة جميع الوحدات الحديدية المستقلة بنجاح، وجميع الإمكانيات متاحة للاستخدام الإنتاجي.", "أخضر")
اكتب("=====================================================")
