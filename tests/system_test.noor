# اختبار فعلي يعمل لأسطر الأوامر (Terminal Test Script)
# يمكنك تشغيله بكتابة الأمر: noor run \tests\system_test.noor

تحميل_مكتبة("stdlib/core.noor")
تحميل_مكتبة("stdlib/network.noor")

اكتب("=======================================")
اكتب("🧪 بدء تشغيل اختبارات الأنظمة المتكاملة للغة نور!")
اكتب("=======================================")

انشئ الزمن_الحالي = الوقت_الآن()
اكتب("الوقت:", الزمن_الحالي)

انشئ هل_آمن = فحص_النظام()
اذا (هل_آمن == صحيح) {
   اكتب("🟢 تخطى الاختبار النظامي بنجاح.")
}

انشئ بيانات = [5, 10, 15, 20]
انشئ المتوسط = حساب_المتوسط(بيانات)
اكتب("متوسط العمليات الحسابية للأرقام:", المتوسط)

إطلاق_سيرفر_متطور(8080, "Noor Test Server")

اكتب("🏁 انتهى ملف الاختبار بنجاح. أداة أسطر الأوامر تعمل بصلاحيات كاملة.")
