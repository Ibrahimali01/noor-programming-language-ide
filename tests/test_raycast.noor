# اختبار مكتبة التصويب الشعاعي Raycast (لألعاب PUBG-like)
تحميل_مكتبة("game_engine")

اكتب("==========================================================================")
اكتب("🏹 اختبار الشعاع القتالي (Raycasting) في بيئات 3D و 2D")
اكتب("==========================================================================")

انشئ لاعب_العدو1 = إنشاء_شخصية_لاعب("العدو البعيد", 100, 50, 0)
انشئ لاعب_العدو2 = إنشاء_شخصية_لاعب("العدو القريب", 20, 10, 0)

انشئ جميع_الأجسام = [لاعب_العدو1, لاعب_العدو2]

اكتب("--- تجربة إطلاق النار لمسافة 50 متر ---")
انشئ الإصابة_الاولى = raycast(0, 0, 1, 1, 50, جميع_الأجسام)

اكتب("--- تجربة إطلاق قناص لمسافة 200 متر ---")
انشئ الإصابة_الثانية = raycast(0, 0, 1, 1, 200, جميع_الأجسام)

اكتب("==========================================================================")
اكتب("✅ تم فحص الميكانيزم بنجاح.")
