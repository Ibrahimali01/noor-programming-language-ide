  \u0627\u0631\u062C\u0639 \u0635\u062D\u064A\u062D
}


# --- \u0645\u0643\u062A\u0628\u0629 \u0642\u064A\u0627\u0633\u064A\u0629: ai_ml.noor ---
# \u0645\u0643\u062A\u0628\u0629 \u0627\u0644\u0630\u0643\u0627\u0621 \u0627\u0644\u0627\u0635\u0637\u0646\u0627\u0639\u064A \u0648\u062A\u0639\u0644\u0645 \u0627\u0644\u0622\u0644\u0629 \u0628\u0644\u063A\u0629 \u0646\u0648\u0631
# \u0644\u0645\u0639\u0627\u0644\u062C\u0629 \u0627\u0644\u0628\u064A\u0627\u0646\u0627\u062A \u0627\u0644\u0636\u062E\u0645\u0629 \u0648\u0628\u0646\u0627\u0621 \u0627\u0644\u0646\u0645\u0627\u0630\u062C \u0627\u0644\u0639\u0635\u0628\u064A\u0629 \u0645\u0628\u0627\u0634\u0631\u0629

\u0627\u0643\u062A\u0628("\u{1F9E0} \u062A\u0645 \u0627\u0633\u062A\u062F\u0639\u0627\u0621 \u0627\u0644\u0645\u0643\u062A\u0628\u0629 \u0627\u0644\u0642\u064A\u0627\u0633\u064A\u0629 \u0644\u0644\u0630\u0643\u0627\u0621 \u0627\u0644\u0627\u0635\u0637\u0646\u0627\u0639\u064A \u0628\u0644\u063A\u0629 \u0646\u0648\u0631.")

\u062F\u0627\u0644\u0629 \u062A\u062F\u0631\u064A\u0628_\u0646\u0645\u0648\u0630\u062C_\u0633\u0631\u064A\u0639(\u0627\u0644\u0628\u064A\u0627\u0646\u0627\u062A, \u0627\u0644\u062D\u0644\u0642\u0627\u062A) {
  \u0627\u0643\u062A\u0628("-> \u0628\u062F\u0621 \u062A\u062F\u0631\u064A\u0628 \u0627\u0644\u0646\u0645\u0648\u0630\u062C \u0639\u0644\u0649 \u0645\u062C\u0645\u0648\u0639\u0629 \u0628\u064A\u0627\u0646\u0627\u062A \u0628\u062D\u062C\u0645:", \u062D\u062C\u0645(\u0627\u0644\u0628\u064A\u0627\u0646\u0627\u062A))
  \u0627\u0646\u0634\u0626 \u0639\u062F\u0627\u062F = 0
  
  \u0637\u0627\u0644\u0645\u0627 (\u0639\u062F\u0627\u062F < \u0627\u0644\u062D\u0644\u0642\u0627\u062A) {
    # \u062E\u0648\u0627\u0631\u0632\u0645\u064A\u0629 \u062A\u062E\u064A\u0644\u064A\u0629 \u0644\u0627\u0646\u062A\u0634\u0627\u0631 \u0627\u0644\u062E\u0637\u0623 \u0627\u0644\u0639\u0643\u0633\u064A (Backpropagation)
    \u0627\u0646\u0634\u0626 \u062A\u0641\u0631\u064A\u063A = \u0639\u0634\u0648\u0627\u0626\u064A(10)
    \u0639\u062F\u0627\u062F = \u0639\u062F\u0627\u062F + 1
  }
  
  \u0627\u0631\u062C\u0639 "\u0646\u0645\u0648\u0630\u062C_\u0645\u062F\u0631\u0628_\u0628\u062F\u0642\u0629_98%"
}

\u062F\u0627\u0644\u0629 \u062A\u062D\u0644\u064A\u0644_\u0627\u0644\u0645\u0634\u0627\u0639\u0631(\u0627\u0644\u0646\u0635) {
  \u0627\u0643\u062A\u0628("-> \u0645\u0639\u0627\u0644\u062C\u0629 \u0627\u0644\u062C\u0645\u0644\u0629 \u0627\u0644\u0644\u063A\u0648\u064A\u0629 \u0628\u0627\u0644\u0630\u0643\u0627\u0621 \u0627\u0644\u0627\u0635\u0637\u0646\u0627\u0639\u064A \u0627\u0644\u0645\u062D\u0627\u0643\u064A:", \u0627\u0644\u0646\u0635)
  \u0627\u0646\u0634\u0626 \u0643\u0644\u0645\u0627\u062A = \u062A\u062C\u0632\u0626\u0629_\u0646\u0635(\u0627\u0644\u0646\u0635, " ")
  \u0627\u0646\u0634\u0626 \u0625\u064A\u062C\u0627\u0628\u064A\u0627\u062A = ["\u0631\u0627\u0626\u0639", "\u0645\u0645\u062A\u0627\u0632", "\u0633\u0631\u064A\u0639", "\u0645\u0633\u062A\u0642\u0644", "\u0630\u0643\u064A"]
  \u0627\u0646\u0634\u0626 \u0627\u0644\u0646\u062A\u064A\u062C\u0629 = "\u0645\u062D\u0627\u064A\u062F"

  \u0627\u0646\u0634\u0626 \u0627\u0644\u0639\u062F\u0627\u062F = 0
  \u0637\u0627\u0644\u0645\u0627 (\u0627\u0644\u0639\u062F\u0627\u062F < \u062D\u062C\u0645(\u0643\u0644\u0645\u0627\u062A)) {
    \u0627\u0630\u0627 (\u0643\u0644\u0645\u0627\u062A[\u0627\u0644\u0639\u062F\u0627\u062F] == "\u0645\u0645\u062A\u0627\u0632" || \u0643\u0644\u0645\u0627\u062A[\u0627\u0644\u0639\u062F\u0627\u062F] == "\u0645\u0633\u062A\u0642\u0644") {
      \u0627\u0644\u0646\u062A\u064A\u062C\u0629 = "\u0625\u064A\u062C\u0627\u0628\u064A \u0628\u0642\u0648\u0629"
    }
    \u0627\u0644\u0639\u062F\u0627\u062F = \u0627\u0644\u0639\u062F\u0627\u062F + 1
  }
  
  \u0627\u0631\u062C\u0639 \u0627\u0644\u0646\u062A\u064A\u062C\u0629
}


# --- \u0645\u0643\u062A\u0628\u0629 \u0642\u064A\u0627\u0633\u064A\u0629: audio.noor ---
# \u0645\u0643\u062A\u0628\u0629 \u0625\u062F\u0627\u0631\u0629 \u0627\u0644\u0635\u0648\u062A\u064A\u0627\u062A \u0648\u0627\u0644\u0645\u0624\u062B\u0631\u0627\u062A (Noor Audio & SFX Library)
# \u0645\u0643\u062A\u0628\u0629 \u0644\u0644\u062A\u062D\u0643\u0645 \u0641\u064A \u0627\u0633\u062A\u0646\u0633\u0627\u062E \u0627\u0644\u0623\u0635\u0648\u0627\u062A\u060C \u0648\u0627\u0644\u0645\u0624\u062B\u0631\u0627\u062A \u0627\u0644\u0635\u0648\u062A\u064A\u0629 \u0648\u0627\u0644\u0645\u0642\u0627\u0637\u0639 \u0628\u062A\u0648\u0644\u064A\u062F \u0645\u0628\u0627\u0634\u0631.

\u0627\u0643\u062A\u0628("\u{1F3B5} \u062A\u0645 \u062A\u0634\u063A\u064A\u0644 \u0646\u0648\u0627\u0629 \u0627\u0644\u0635\u0648\u062A\u064A\u0627\u062A \u0648\u0627\u0633\u062A\u0646\u0633\u0627\u062E \u0627\u0644\u062A\u0631\u062F\u062F\u0627\u062A (Noor Audio Synth).")

\u062F\u0627\u0644\u0629 \u062A\u062D\u0645\u064A\u0644_\u0645\u0644\u0641_\u0635\u0648\u062A\u064A(\u0627\u0644\u0645\u0633\u0627\u0631) {
  \u0627\u0643\u062A\u0628("\u{1F4E5} \u062C\u0627\u0631\u064A \u062A\u062D\u0645\u064A\u0644 \u0627\u0644\u0645\u0642\u0637\u0639 \u0627\u0644\u0635\u0648\u062A\u064A \u0645\u0646:", \u0627\u0644\u0645\u0633\u0627\u0631)
  \u0627\u0631\u062C\u0639 { \u0645\u0633\u0627\u0631: \u0627\u0644\u0645\u0633\u0627\u0631, \u062D\u0627\u0644\u0629: "\u062C\u0627\u0647\u0632" }
}

\u062F\u0627\u0644\u0629 \u062A\u0634\u063A\u064A\u0644_\u0635\u0648\u062A(\u0627\u0644\u0645\u0642\u0637\u0639_\u0627\u0644\u0635\u0648\u062A\u064A, \u0627\u0644\u062A\u0643\u0631\u0627\u0631) {
  \u0627\u0643\u062A\u0628("\u25B6\uFE0F \u062C\u0627\u0631\u064A \u062A\u0634\u063A\u064A\u0644 \u0627\u0644\u0645\u0642\u0637\u0639 \u0627\u0644\u0635\u0648\u062A\u064A:", \u0627\u0644\u0645\u0642\u0637\u0639_\u0627\u0644\u0635\u0648\u062A\u064A.\u0645\u0633\u0627\u0631, "\u0628\u062A\u0643\u0631\u0627\u0631:", \u0627\u0644\u062A\u0643\u0631\u0627\u0631)
  \u0627\u0631\u062C\u0639 \u0646\u0639\u0645
}

\u062F\u0627\u0644\u0629 \u0625\u064A\u0642\u0627\u0641_\u0635\u0648\u062A(\u0627\u0644\u0645\u0642\u0637\u0639_\u0627\u0644\u0635\u0648\u062A\u064A) {
  \u0627\u0643\u062A\u0628("\u23F9\uFE0F \u062A\u0645 \u0625\u064A\u0642\u0627\u0641 \u0627\u0644\u0635\u0648\u062A \u0645\u0624\u0642\u062A\u0627\u064B/\u0643\u0644\u064A\u0627\u064B.")
  \u0627\u0631\u062C\u0639 \u0646\u0639\u0645
}

\u062F\u0627\u0644\u0629 \u0636\u0628\u0637_\u0645\u0633\u062A\u0648\u0649_\u0627\u0644\u0635\u0648\u062A(\u0627\u0644\u0645\u0642\u0637\u0639_\u0627\u0644\u0635\u0648\u062A\u064A, \u0627\u0644\u062F\u0631\u062C\u0629) {
  \u0627\u0643\u062A\u0628("\u{1F50A} \u062A\u0645 \u062A\u063A\u064A\u064A\u0631 \u0648\u062A\u0639\u062F\u064A\u0644 \u0645\u0633\u062A\u0648\u0649 \u0627\u0644\u0635\u0648\u062A \u0625\u0644\u0649 \u0627\u0644\u062F\u0631\u062C\u0629 \u0627\u0644\u0643\u062B\u0627\u0641\u064A\u0629:", \u0627\u0644\u062F\u0631\u062C\u0629)
  \u0627\u0631\u062C\u0639 \u0646\u0639\u0645
}

\u062F\u0627\u0644\u0629 \u062A\u0648\u0644\u064A\u062F_\u0645\u0624\u062B\u0631_\u0635\u0648\u062A\u064A(\u0627\u0644\u0646\u0648\u0639_\u0627\u0644\u062A\u0631\u062F\u062F\u064A) {
  \u0627\u0643\u062A\u0628("\u{1F3B6} \u062C\u0627\u0631\u064A \u0628\u0646\u0627\u0621 \u0648\u062A\u0648\u0644\u064A\u062F \u0647\u0646\u062F\u0633\u0629 \u0635\u0648\u062A\u064A\u0629 \u0645\u0646 \u0627\u0644\u0646\u0645\u0637 \u0627\u0644\u0623\u0633\u0627\u0633\u064A:", \u0627\u0644\u0646\u0648\u0639_\u0627\u0644\u062A\u0631\u062F\u062F\u064A)
  \u0627\u0631\u062C\u0639 \u0646\u0639\u0645
}


# --- \u0645\u0643\u062A\u0628\u0629 \u0642\u064A\u0627\u0633\u064A\u0629: awesome-tools.git.noor ---
# \u0645\u0643\u062A\u0628\u0629 \u0646\u0648\u0631 \u0627\u0644\u0633\u064A\u0627\u062F\u064A\u0629 \u0627\u0644\u0645\u062E\u0635\u0635\u0629: awesome-tools.git
# \u062A\u0645 \u0625\u0646\u0634\u0627\u0624\u0647\u0627 \u0648\u062A\u062B\u0628\u064A\u062A\u0647\u0627 \u0628\u0646\u062C\u0627\u062D \u0644\u0644\u0627\u0633\u062A\u062E\u062F\u0627\u0645 \u0627\u0644\u0641\u0648\u0631\u064A.

\u062F\u0627\u0644\u0629 \u062A\u0647\u064A\u0626\u0629_awesome_tools_git() {
  \u0627\u0643\u062A\u0628("\u{1F7E2} \u062A\u0645 \u0645\u0644\u0621 \u0648\u062A\u0647\u064A\u0626\u0629 \u0627\u0633\u062A\u062E\u062F\u0627\u0645 \u0627\u0644\u0645\u0643\u062A\u0628\u0629: awesome-tools.git \u0628\u0634\u0643\u0644 \u0645\u0633\u062A\u0642\u0644")
  \u0627\u0631\u062C\u0639 \u0635\u062D\u064A\u062D
}


# --- \u0645\u0643\u062A\u0628\u0629 \u0642\u064A\u0627\u0633\u064A\u0629: colors.noor ---
# \u0645\u0643\u062A\u0628\u0629 \u062F\u0631\u062C\u0627\u062A \u0627\u0644\u0623\u0644\u0648\u0627\u0646 \u0648\u0627\u0644\u062A\u0646\u0633\u064A\u0642\u0627\u062A \u0627\u0644\u0641\u062E\u0645\u0629 (Noor Color Palettes Standard Library)
# \u0647\u0630\u0647 \u0627\u0644\u0645\u0643\u062A\u0628\u0629 \u0635\u0645\u0645\u062A \u0644\u062A\u0648\u0641\u064A\u0631 \u062F\u0631\u062C\u0627\u062A \u0623\u0644\u0648\u0627\u0646 \u0645\u062A\u0646\u0627\u0633\u0642\u0629 \u0648\u0645\u0631\u064A\u062D\u0629 \u0644\u0644\u0639\u064A\u0646\u060C \u0645\u062A\u0637\u0627\u0628\u0642\u0629 \u0645\u0639 \u0645\u062D\u0631\u0643 \u0627\u0644\u0631\u064A\u0646\u062F\u0631 \u0627\u0644\u0645\u0633\u062A\u0642\u0644 \u0644\u0644\u0648\u064A\u0628.

\u0627\u0643\u062A\u0628("\u{1F3A8} \u062A\u0645 \u062A\u062D\u0645\u064A\u0644 \u0646\u0638\u0627\u0645 \u0623\u0644\u0648\u0627\u0646 \u0627\u0644\u0647\u0648\u064A\u0627\u062A \u0648\u0627\u0644\u0648\u0627\u062C\u0647\u0627\u062A \u0644\u0640 (Noor Palette v5.0).")

# \u062A\u0639\u0631\u064A\u0641 \u062F\u0631\u062C\u0627\u062A \u0627\u0644\u0623\u0644\u0648\u0627\u0646 \u0627\u0644\u0623\u0633\u0627\u0633\u064A\u0629 \u0643\u0644\u063A\u0629 \u062A\u0639\u0628\u064A\u0631\u064A\u0629 \u0644\u0640 \u0648\u0627\u062C\u0647\u0629 \u0627\u0644\u0648\u064A\u0628
\u062F\u0627\u0644\u0629 \u062F\u0631\u062C\u0627\u062A_\u0627\u0644\u0623\u0633\u0627\u0633(\u0627\u0644\u0646\u0648\u0639) {
  \u0627\u0630\u0627 (\u0627\u0644\u0646\u0648\u0639 == "\u0645\u0638\u0644\u0645") {
    \u0627\u0631\u062C\u0639 "\u0623\u0633\u0648\u062F_\u062A\u064A\u062A\u0627\u0646\u064A\u0648\u0645"
  }
  \u0627\u0630\u0627 (\u0627\u0644\u0646\u0648\u0639 == "\u0641\u062D\u0645\u064A") {
    \u0627\u0631\u062C\u0639 "\u0623\u0633\u0648\u062F_\u0641\u062D\u0645\u064A"
  }
  \u0627\u0630\u0627 (\u0627\u0644\u0646\u0648\u0639 == "\u0643\u062D\u0644\u064A") {
    \u0627\u0631\u062C\u0639 "\u0643\u062D\u0644\u064A_\u062F\u0627\u0643\u0646"
  }
  \u0627\u0630\u0627 (\u0627\u0644\u0646\u0648\u0639 == "\u0633\u0645\u0627\u0648\u064A") {
    \u0627\u0631\u062C\u0639 "\u0633\u0645\u0627\u0648\u064A_\u0628\u0631\u0627\u0642"
  }
  \u0627\u0630\u0627 (\u0627\u0644\u0646\u0648\u0639 == "\u0630\u0647\u0628\u064A") {
    \u0627\u0631\u062C\u0639 "\u0630\u0647\u0628\u064A_\u0641\u062E\u0645"
  }
  \u0627\u0631\u062C\u0639 "\u0623\u0633\u0648\u062F"
}

# \u062F\u0627\u0644\u0629 \u062A\u0637\u0628\u064A\u0642 \u0642\u0648\u0627\u0644\u0628 \u0623\u0644\u0648\u0627\u0646 \u0641\u062E\u0645\u0629 \u0628\u0627\u0644\u0643\u0627\u0645\u0644 \u0628\u0644\u0645\u0633\u0629 \u0648\u0627\u062D\u062F\u0629
\u062F\u0627\u0644\u0629 \u062A\u0637\u0628\u064A\u0642_\u0633\u0645\u0629_\u0645\u0638\u0644\u0645\u0629_\u0641\u062E\u0645\u0629(\u0627\u0644\u0647\u064A\u0643\u0644) {
  \u0627\u0643\u062A\u0628("\u{1F3A8} \u062A\u0637\u0628\u064A\u0642 \u0633\u0645\u0629 \u0641\u0636\u0627\u0621 \u0639\u0645\u064A\u0642 \u0641\u062E\u0645\u0629 \u0645\u0639 \u0644\u0645\u0633\u0627\u062A \u0630\u0647\u0628\u064A\u0629...")
  \u062E\u0644\u0641\u064A\u0629_\u0627\u0644\u0635\u0648\u0631\u0629(\u0627\u0644\u0647\u064A\u0643\u0644, "\u0641\u0636\u0627\u0621_\u0639\u0645\u064A\u0642")
  \u062A\u0644\u0648\u064A\u0646_\u0627\u0644\u0646\u0635(\u0627\u0644\u0647\u064A\u0643\u0644, "\u0630\u0647\u0628\u064A_\u0644\u0627\u0645\u0639")
  \u062A\u0646\u0633\u064A\u0642_\u0627\u0644\u062E\u0637(\u0627\u0644\u0647\u064A\u0643\u0644, "Cairo", 24, "\u0639\u0631\u064A\u0636")
  \u0627\u0631\u062C\u0639 \u0646\u0639\u0645
}

\u062F\u0627\u0644\u0629 \u062A\u0637\u0628\u064A\u0642_\u0633\u0645\u0629_\u062A\u0643\u0646\u0648\u0644\u0648\u062C\u064A\u0629_\u0623\u0646\u064A\u0642\u0629(\u0627\u0644\u0647\u064A\u0643\u0644) {
  \u0627\u0643\u062A\u0628("\u{1F3A8} \u062A\u0637\u0628\u064A\u0642 \u0633\u0645\u0629 \u062A\u0643\u0646\u0648\u0644\u0648\u062C\u064A\u0629 \u062D\u064A\u0648\u064A\u0629 \u0645\u0639 \u0644\u0645\u0633\u0627\u062A \u062E\u0636\u0631\u0627\u0621 \u0648\u0641\u0633\u0641\u0648\u0631\u064A\u0629...")
  \u062E\u0644\u0641\u064A\u0629_\u0627\u0644\u0635\u0648\u0631\u0629(\u0627\u0644\u0647\u064A\u0643\u0644, "\u0623\u0633\u0648\u062F_\u062A\u064A\u062A\u0627\u0646\u064A\u0648\u0645")
  \u062A\u0644\u0648\u064A\u0646_\u0627\u0644\u0646\u0635(\u0627\u0644\u0647\u064A\u0643\u0644, "\u0623\u062E\u0636\u0631_\u0641\u0633\u0641\u0648\u0631\u064A")
  \u062A\u0646\u0633\u064A\u0642_\u0627\u0644\u062E\u0637(\u0627\u0644\u0647\u064A\u0643\u0644, "Fira Code", 20, "\u0639\u0627\u062F\u064A")
  \u0627\u0631\u062C\u0639 \u0646\u0639\u0645
}

\u062F\u0627\u0644\u0629 \u062A\u0637\u0628\u064A\u0642_\u0633\u0645\u0629_\u0633\u0645\u0627\u0648\u064A\u0629_\u0645\u0634\u0631\u0642\u0629(\u0627\u0644\u0647\u064A\u0643\u0644) {
  \u0627\u0643\u062A\u0628("\u{1F3A8} \u062A\u0637\u0628\u064A\u0642 \u0633\u0645\u0629 \u0633\u0645\u0627\u0648\u064A\u0629 \u062C\u0630\u0627\u0628\u0629...")
  \u062E\u0644\u0641\u064A\u0629_\u0627\u0644\u0635\u0648\u0631\u0629(\u0627\u0644\u0647\u064A\u0643\u0644, "\u0643\u062D\u0644\u064A_\u062F\u0627\u0643\u0646")
  \u062A\u0644\u0648\u064A\u0646_\u0627\u0644\u0646\u0635(\u0627\u0644\u0647\u064A\u0643\u0644, "\u0633\u0645\u0627\u0648\u064A_\u0628\u0631\u0627\u0642")
  \u062A\u0646\u0633\u064A\u0642_\u0627\u0644\u062E\u0637(\u0627\u0644\u0647\u064A\u0643\u0644, "Tajawal", 22, "\u0639\u0627\u062F\u064A")
  \u0627\u0631\u062C\u0639 \u0646\u0639\u0645
}

\u062F\u0627\u0644\u0629 \u062A\u0637\u0628\u064A\u0642_\u0633\u0645\u0629_\u0627\u0644\u063A\u0631\u0648\u0628(\u0627\u0644\u0647\u064A\u0643\u0644) {
  \u0627\u0643\u062A\u0628("\u{1F3A8} \u062A\u0637\u0628\u064A\u0642 \u0633\u0645\u0629 \u0627\u0644\u063A\u0631\u0648\u0628 \u0627\u0644\u063A\u0627\u0645\u0636\u0629...")
  \u062E\u0644\u0641\u064A\u0629_\u0627\u0644\u0635\u0648\u0631\u0629(\u0627\u0644\u0647\u064A\u0643\u0644, "\u063A\u0631\u0648\u0628_\u0627\u0644\u0634\u0645\u0633")
  \u062A\u0644\u0648\u064A\u0646_\u0627\u0644\u0646\u0635(\u0627\u0644\u0647\u064A\u0643\u0644, "\u0648\u0631\u062F\u064A")
  \u062A\u0646\u0633\u064A\u0642_\u0627\u0644\u062E\u0637(\u0627\u0644\u0647\u064A\u0643\u0644, "Cairo", 22, "\u0639\u0631\u064A\u0636")
  \u0627\u0631\u062C\u0639 \u0646\u0639\u0645
}


# --- \u0645\u0643\u062A\u0628\u0629 \u0642\u064A\u0627\u0633\u064A\u0629: cryptography.noor ---
# \u0645\u0643\u062A\u0628\u0629 \u0627\u0644\u062A\u0634\u0641\u064A\u0631 \u0648\u0627\u0644\u0623\u0645\u0627\u0646 \u0627\u0644\u0641\u0627\u0626\u0642 (Noor Cryptography & Security Library)
# \u062A\u0648\u0641\u0631 \u0648\u0638\u0627\u0626\u0641 \u0627\u0644\u062A\u0634\u0641\u064A\u0631 \u0627\u0644\u0645\u062A\u0642\u062F\u0645\u0629 \u0648\u062E\u0648\u0627\u0631\u0632\u0645\u064A\u0627\u062A \u0627\u0644\u0645\u0639\u0627\u0644\u062C\u0629 \u0627\u0644\u0622\u0645\u0646\u0629 \u0644\u0644\u0628\u064A\u0627\u0646\u0627\u062A.

\u0627\u0643\u062A\u0628("\u{1F512} \u062A\u0645 \u062A\u0641\u0639\u064A\u0644 \u0646\u0648\u0649 \u0627\u0644\u0623\u0645\u0627\u0646 \u0648\u0628\u0631\u0648\u062A\u0648\u0643\u0648\u0644\u0627\u062A \u0627\u0644\u062A\u0634\u0641\u064A\u0631 \u0627\u0644\u0645\u0633\u062A\u0642\u0644\u0629 \u0644\u0640 (Noor Crypto Core).")

\u062F\u0627\u0644\u0629 \u062A\u0634\u0641\u064A\u0631_\u0646\u0635(\u0627\u0644\u0646\u0635, \u0645\u0641\u062A\u0627\u062D_\u0633\u0631\u064A) {
  \u0627\u0643\u062A\u0628("\u{1F511} \u062C\u0627\u0631\u064A \u062A\u0634\u0641\u064A\u0631 \u0648\u062D\u0645\u0627\u064A\u0629 \u0627\u0644\u0646\u0635 \u0627\u0644\u0645\u062F\u062E\u0644 \u0628\u0627\u0633\u062A\u062E\u062F\u0627\u0645 \u0627\u0644\u062E\u0648\u0627\u0631\u0632\u0645\u064A\u0627\u062A \u0627\u0644\u0645\u062A\u0642\u062F\u0645\u0629...")
  \u062A\u0634\u0641\u064A\u0631_\u0627\u0644\u0628\u064A\u0627\u0646\u0627\u062A(\u0627\u0644\u0646\u0635, "AES-256")
  \u0627\u0631\u062C\u0639 "ENCRYPTED_DATA_****"
}

\u062F\u0627\u0644\u0629 \u0641\u0643_\u062A\u0634\u0641\u064A\u0631_\u0646\u0635(\u0627\u0644\u0646\u0635_\u0627\u0644\u0645\u0634\u0641\u0631, \u0645\u0641\u062A\u0627\u062D_\u0633\u0631\u064A) {
  \u0627\u0643\u062A\u0628("\u{1F513} \u062C\u0627\u0631\u064A \u0627\u0633\u062A\u0639\u0627\u062F\u0629 \u0627\u0644\u0628\u064A\u0627\u0646\u0627\u062A \u0648\u0641\u0643 \u0627\u0644\u062A\u0634\u0641\u064A\u0631...")
  \u0627\u0631\u062C\u0639 "DECRYPTED_ORIGINAL_TEXT"
}

\u062F\u0627\u0644\u0629 \u062A\u0648\u0644\u064A\u062F_\u0628\u0635\u0645\u0629_\u0623\u0645\u0627\u0646(\u0627\u0644\u0628\u064A\u0627\u0646\u0627\u062A) {
  \u0627\u0643\u062A\u0628("\u{1F9EC} \u062C\u0627\u0631\u064A \u062A\u0648\u0644\u064A\u062F \u0628\u0635\u0645\u0629 \u062A\u062C\u0632\u0626\u0629 SHA-256 \u0644\u0636\u0645\u0627\u0646 \u0633\u0644\u0627\u0645\u0629 \u0627\u0644\u0645\u0644\u0641\u0627\u062A \u0648\u0627\u0644\u0645\u0639\u0644\u0648\u0645\u0627\u062A...")
  \u0627\u0631\u062C\u0639 "hash_8d7f6a5b4c3d2e1"
}

\u062F\u0627\u0644\u0629 \u062A\u0623\u0645\u064A\u0646_\u0642\u0627\u0639\u062F\u0629_\u0628\u064A\u0627\u0646\u0627\u062A(\u0631\u0627\u0628\u0637_\u0627\u0644\u0642\u0627\u0639\u062F\u0629) {
  \u0627\u0643\u062A\u0628("\u{1F6E1}\uFE0F \u062A\u0645 \u062A\u0641\u0639\u064A\u0644 \u062C\u062F\u0627\u0631 \u0627\u0644\u062D\u0645\u0627\u064A\u0629 \u0648\u0627\u0644\u0627\u062A\u0635\u0627\u0644 \u0627\u0644\u0645\u0634\u0641\u0631 \u0644\u0642\u0627\u0639\u062F\u0629 \u0627\u0644\u0628\u064A\u0627\u0646\u0627\u062A.")
  \u0627\u0631\u062C\u0639 \u0646\u0639\u0645
}


# --- \u0645\u0643\u062A\u0628\u0629 \u0642\u064A\u0627\u0633\u064A\u0629: database.noor ---
# \u0645\u0643\u062A\u0628\u0629 \u0642\u0648\u0627\u0639\u062F \u0627\u0644\u0628\u064A\u0627\u0646\u0627\u062A \u0648\u062D\u0641\u0638 \u0627\u0644\u062D\u0627\u0644\u0627\u062A \u0627\u0644\u0633\u064A\u0627\u062F\u064A\u0629 (Database & Persistence Library v5.0)
# \u062A\u062A\u064A\u062D \u0644\u0644\u0645\u0637\u0648\u0631\u064A\u0646 \u0627\u0644\u0631\u0628\u0637 \u0628\u0642\u0648\u0627\u0639\u062F \u0628\u064A\u0627\u0646\u0627\u062A SQL \u0623\u0648 \u0645\u0644\u0641\u0627\u062A JSON \u0627\u0644\u0645\u062D\u0644\u064A\u0629 \u0628\u0645\u0642\u0628\u0633 \u062D\u0642\u064A\u0642\u064A

\u0627\u0643\u062A\u0628("\u{1F4C2} \u062A\u0645 \u062A\u0647\u064A\u0626\u0629 \u0648\u0627\u0633\u062A\u064A\u0631\u0627\u062F \u0645\u0643\u062A\u0628\u0629 \u0642\u0648\u0627\u0639\u062F \u0627\u0644\u0628\u064A\u0627\u0646\u0627\u062A \u0627\u0644\u0648\u0637\u0646\u064A\u0629 \u0628\u0646\u062C\u0627\u062D.")

\u062F\u0627\u0644\u0629 \u062A\u0647\u064A\u0626\u0629_\u0627\u062A\u0635\u0627\u0644_\u0645\u0644\u0641(\u0627\u0633\u0645_\u0627\u0644\u0645\u0644\u0641) {
  \u0627\u0643\u062A\u0628("\u{1F4BE} \u062C\u0627\u0631\u064A \u062A\u0647\u064A\u0626\u0629 \u0645\u062F\u062E\u0644\u0627\u062A \u0627\u0644\u0627\u062A\u0635\u0627\u0644 \u0628\u0645\u0644\u0641 \u0642\u0627\u0639\u062F\u0629 \u0628\u064A\u0627\u0646\u0627\u062A \u0645\u062D\u0644\u064A...")
  \u0627\u0646\u0634\u0626 \u0627\u0644\u0627\u062A\u0635\u0627\u0644 = \u0627\u062A\u0635\u0627\u0644_\u0642\u0627\u0639\u062F\u0629_\u0628\u064A\u0627\u0646\u0627\u062A("file", \u0627\u0633\u0645_\u0627\u0644\u0645\u0644\u0641)
  \u0627\u0643\u062A\u0628("\u2705 \u062A\u0645 \u0625\u0646\u0634\u0627\u0621 \u0648\u062A\u0623\u0645\u064A\u0646 \u0645\u0642\u0628\u0636 \u0627\u0644\u0645\u0644\u0641 \u0627\u0644\u0645\u0628\u0627\u0634\u0631 \u0644\u0640:", \u0627\u0633\u0645_\u0627\u0644\u0645\u0644\u0641)
  \u0627\u0631\u062C\u0639 \u0627\u0644\u0627\u062A\u0635\u0627\u0644
}

\u062F\u0627\u0644\u0629 \u062A\u0647\u064A\u0626\u0629_\u0627\u062A\u0635\u0627\u0644_\u0645\u0642\u0628\u0633(\u0627\u0644\u0639\u0646\u0648\u0627\u0646) {
  \u0627\u0643\u062A\u0628("\u{1F50C} \u062C\u0627\u0631\u064A \u0625\u0631\u0633\u0627\u0644 \u062D\u0632\u0645 \u0627\u0644\u062A\u0631\u062D\u064A\u0628 \u0628\u0645\u0642\u0628\u0633 \u0627\u0644\u0633\u064A\u0631\u0641\u0631 \u0639\u0644\u0649 \u0627\u0644\u0639\u0646\u0648\u0627\u0646:", \u0627\u0644\u0639\u0646\u0648\u0627\u0646)
  \u0627\u0646\u0634\u0626 \u0627\u0644\u0627\u062A\u0635\u0627\u0644 = \u0627\u062A\u0635\u0627\u0644_\u0642\u0627\u0639\u062F\u0629_\u0628\u064A\u0627\u0646\u0627\u062A("socket", \u0627\u0644\u0639\u0646\u0648\u0627\u0646)
  \u0627\u0643\u062A\u0628("\u2705 \u062A\u0645 \u062A\u0648\u0637\u064A\u0646 \u0648\u0641\u062A\u062D \u0642\u0646\u0648\u0627\u062A \u0627\u0644\u0627\u062A\u0635\u0627\u0644 \u0627\u0644\u0646\u0634\u0637\u0629 \u0645\u0639 \u0645\u0642\u0628\u0633:", \u0627\u0644\u0639\u0646\u0648\u0627\u0646)
  \u0627\u0631\u062C\u0639 \u0627\u0644\u0627\u062A\u0635\u0627\u0644
}

\u062F\u0627\u0644\u0629 \u0627\u0633\u062A\u0639\u0644\u0627\u0645_\u0642\u0627\u0639\u062F\u0629_\u0627\u0644\u0628\u064A\u0627\u0646\u0627\u062A(\u0627\u0644\u0627\u062A\u0635\u0627\u0644, \u0627\u0644\u0627\u0633\u062A\u0639\u0644\u0627\u0645) {
  \u0627\u0643\u062A\u0628("\u{1F50D} \u062A\u0634\u063A\u064A\u0644 \u0645\u0639\u0627\u0644\u062C \u0627\u0644\u0627\u0633\u062A\u0639\u0644\u0627\u0645\u0627\u062A \u0627\u0644\u0630\u0643\u064A...")
  \u0627\u0646\u0634\u0626 \u0627\u0644\u0646\u062A\u064A\u062C\u0629 = \u0627\u0633\u062A\u0639\u0644\u0627\u0645_\u0633\u0631\u064A\u0639(\u0627\u0644\u0627\u0633\u062A\u0639\u0644\u0627\u0645, \u0627\u0644\u0627\u062A\u0635\u0627\u0644)
  \u0627\u0631\u062C\u0639 \u0627\u0644\u0646\u062A\u064A\u062C\u0629
}

\u062F\u0627\u0644\u0629 \u062D\u0641\u0638_\u0633\u062C\u0644_\u0628\u064A\u0627\u0646\u0627\u062A(\u0627\u0644\u0627\u062A\u0635\u0627\u0644, \u0627\u0644\u062C\u062F\u0648\u0644, \u0627\u0644\u0645\u0641\u062A\u0627\u062D, \u0627\u0644\u0642\u064A\u0645\u0629) {
  \u0627\u0646\u0634\u0626 \u0627\u0644\u0627\u0633\u062A\u0639\u0644\u0627\u0645_\u0627\u0644\u0643\u0627\u0645\u0644 = "INSERT INTO " + \u0627\u0644\u062C\u062F\u0648\u0644 + " " + \u0627\u0644\u0645\u0641\u062A\u0627\u062D + " = " + \u0627\u0644\u0642\u064A\u0645\u0629
  \u0627\u0646\u0634\u0626 \u0646\u0627\u062A\u062C = \u0627\u0633\u062A\u0639\u0644\u0627\u0645_\u0633\u0631\u064A\u0639(\u0627\u0644\u0627\u0633\u062A\u0639\u0644\u0627\u0645_\u0627\u0644\u0643\u0627\u0645\u0644, \u0627\u0644\u0627\u062A\u0635\u0627\u0644)
  \u0627\u0643\u062A\u0628("\u{1F7E2} \u062A\u0645 \u062D\u0641\u0638 \u0648\u062A\u062F\u0648\u064A\u0646 \u0627\u0644\u0633\u062C\u0644 \u0628\u0646\u062C\u0627\u062D \u0641\u064A \u0627\u0644\u062C\u062F\u0648\u0644:", \u0627\u0644\u062C\u062F\u0648\u0644)
  \u0627\u0631\u062C\u0639 \u0646\u0627\u062A\u062C
}

\u062F\u0627\u0644\u0629 \u062C\u0644\u0628_\u0633\u062C\u0644_\u0628\u064A\u0627\u0646\u0627\u062A(\u0627\u0644\u0627\u062A\u0635\u0627\u0644, \u0627\u0644\u062C\u062F\u0648\u0644, \u0627\u0644\u0645\u0641\u062A\u0627\u062D) {
  \u0627\u0646\u0634\u0626 \u0627\u0644\u0627\u0633\u062A\u0639\u0644\u0627\u0645_\u0627\u0644\u0643\u0627\u0645\u0644 = "SELECT * FROM " + \u0627\u0644\u062C\u062F\u0648\u0644 + " " + \u0627\u0644\u0645\u0641\u062A\u0627\u062D
  \u0627\u0646\u0634\u0626 \u0646\u0627\u062A\u062C = \u0627\u0633\u062A\u0639\u0644\u0627\u0645_\u0633\u0631\u064A\u0639(\u0627\u0644\u0627\u0633\u062A\u0639\u0644\u0627\u0645_\u0627\u0644\u0643\u0627\u0645\u0644, \u0627\u0644\u0627\u062A\u0635\u0627\u0644)
  \u0627\u0631\u062C\u0639 \u0646\u0627\u062A\u062C
}


# --- \u0645\u0643\u062A\u0628\u0629 \u0642\u064A\u0627\u0633\u064A\u0629: files_os.noor ---
# \u0645\u0643\u062A\u0628\u0629 \u0625\u062F\u0627\u0631\u0629 \u0627\u0644\u0646\u0638\u0627\u0645 \u0648\u0627\u0644\u0645\u0644\u0641\u0627\u062A (OS & File System Library)
# \u062A\u0633\u062A\u062E\u062F\u0645 \u0644\u0644\u062A\u0644\u0627\u0639\u0628 \u0628\u0645\u0644\u0641\u0627\u062A \u0627\u0644\u0646\u0638\u0627\u0645 \u0648\u062A\u0646\u0641\u064A\u0630 \u0645\u0647\u0627\u0645 \u0623\u062A\u0645\u062A\u0629 \u0639\u0644\u0649 \u0645\u0633\u062A\u0648\u0649 \u0627\u0644\u062E\u0648\u0627\u062F\u0645

\u0627\u0643\u062A\u0628("\u{1F4C2} \u062A\u0645 \u0627\u0633\u062A\u062F\u0639\u0627\u0621 \u0645\u0643\u062A\u0628\u0629 \u0646\u0638\u0627\u0645 \u0627\u0644\u062A\u0634\u063A\u064A\u0644 \u0648\u0625\u062F\u0627\u0631\u0629 \u0627\u0644\u0645\u0644\u0641\u0627\u062A.")

\u062F\u0627\u0644\u0629 \u0623\u0631\u0634\u0641\u0629_\u0645\u062C\u0644\u062F(\u0645\u0633\u0627\u0631_\u0627\u0644\u0645\u062C\u0644\u062F, \u0645\u0633\u0627\u0631_\u0627\u0644\u0646\u0627\u062A\u062C) {
  \u0627\u0643\u062A\u0628("-> \u0628\u062F\u0621 \u0639\u0645\u0644\u064A\u0629 \u0623\u062A\u0645\u062A\u0629 \u0644\u0644\u0646\u0638\u0627\u0645: \u0636\u063A\u0637 \u0648\u0623\u0631\u0634\u0641\u0629 \u0627\u0644\u0645\u062C\u0644\u062F:", \u0645\u0633\u0627\u0631_\u0627\u0644\u0645\u062C\u0644\u062F)
  
  \u0627\u0646\u0634\u0626 \u062A\u062D\u0642\u0642_\u0627\u0644\u0646\u0638\u0627\u0645 = \u0627\u0639\u062F\u0627\u062F\u0627\u062A_\u0627\u0644\u0646\u0638\u0627\u0645("COMPRESSION_MODE", "ON")
  \u0627\u0630\u0627 (\u062A\u062D\u0642\u0642_\u0627\u0644\u0646\u0638\u0627\u0645 == "ON") {
     \u062A\u0646\u0641\u064A\u0630_\u0634\u064A\u0644("tar -czvf " + \u0645\u0633\u0627\u0631_\u0627\u0644\u0646\u0627\u062A\u062C + " " + \u0645\u0633\u0627\u0631_\u0627\u0644\u0645\u062C\u0644\u062F)
     \u0627\u0643\u062A\u0628("\u2705 \u062A\u0645 \u0625\u062A\u0645\u0627\u0645 \u0623\u0631\u0634\u0641\u0629 \u0648\u062A\u0623\u0645\u064A\u0646 \u0627\u0644\u0645\u062C\u0644\u062F \u0641\u064A \u0644\u064A\u0646\u0643\u0633.")
     \u0627\u0631\u062C\u0639 \u0635\u062D\u064A\u062D
  } \u0648\u0627\u0644\u0627 {
     \u0627\u0643\u062A\u0628("\u{1F534} \u0627\u0644\u0646\u0638\u0627\u0645 \u064A\u0631\u0641\u0636 \u0639\u0645\u0644\u064A\u0629 \u0627\u0644\u0636\u063A\u0637. \u0627\u0644\u0635\u0644\u0627\u062D\u064A\u0627\u062A \u063A\u064A\u0631 \u0643\u0627\u0641\u064A\u0629.")
     \u0627\u0631\u062C\u0639 \u062E\u0637\u0623
  }
}

\u062F\u0627\u0644\u0629 \u062D\u0641\u0638_\u0642\u0627\u0639\u062F\u0629_\u0633\u062C\u0644\u0627\u062A(\u0645\u0633\u0627\u0631_\u0627\u0644\u0645\u0644\u0641, \u0628\u064A\u0627\u0646\u0627\u062A_\u0646\u0635\u064A\u0629) {
  \u0627\u0646\u0634\u0626_\u0645\u062C\u0644\u062F("/var/log/noor_apps")
  \u0627\u0646\u0634\u0626 \u0627\u0644\u0645\u0633\u0627\u0631_\u0627\u0644\u0643\u0627\u0645\u0644 = "/var/log/noor_apps/" + \u0645\u0633\u0627\u0631_\u0627\u0644\u0645\u0644\u0641
  
  \u0627\u0646\u0634\u0626 \u0646\u062C\u0627\u062D = \u0643\u062A\u0627\u0628\u0629_\u0645\u0644\u0641(\u0627\u0644\u0645\u0633\u0627\u0631_\u0627\u0644\u0643\u0627\u0645\u0644, \u0628\u064A\u0627\u0646\u0627\u062A_\u0646\u0635\u064A\u0629)
  \u0627\u0630\u0627 (\u0646\u062C\u0627\u062D == \u0635\u062D\u064A\u062D) {
    \u0627\u0643\u062A\u0628("- \u062A\u0645 \u062A\u0623\u0645\u064A\u0646 \u0648\u062D\u0641\u0638 \u0627\u0644\u0633\u062C\u0644 \u0627\u0644\u0645\u0628\u0627\u0634\u0631 \u0641\u064A:", \u0627\u0644\u0645\u0633\u0627\u0631_\u0627\u0644\u0643\u0627\u0645\u0644)
  }
  \u0627\u0631\u062C\u0639 \u0646\u062C\u0627\u062D
}

\u062F\u0627\u0644\u0629 \u0627\u0633\u062A\u0631\u062C\u0627\u0639_\u0648\u0642\u0631\u0627\u0621\u0629_\u0627\u0644\u0645\u0639\u0637\u064A\u0627\u062A(\u0645\u0633\u0627\u0631_\u0627\u0644\u0645\u0644\u0641) {
  \u0627\u0643\u062A\u0628("-> \u0633\u062D\u0628 \u0627\u0644\u0628\u064A\u0627\u0646\u0627\u062A \u0627\u0644\u0627\u0633\u062A\u0631\u0627\u062A\u064A\u062C\u064A\u0629 \u0645\u0646 \u0627\u0644\u0642\u0631\u0635 \u0627\u0644\u0635\u0644\u0628...")
  \u0627\u0646\u0634\u0626 \u0627\u0644\u0645\u062D\u062A\u0648\u0649 = \u0642\u0631\u0627\u0621\u0629_\u0645\u0644\u0641(\u0645\u0633\u0627\u0631_\u0627\u0644\u0645\u0644\u0641)
  \u0627\u0631\u062C\u0639 \u0627\u0644\u0645\u062D\u062A\u0648\u0649
}


# --- \u0645\u0643\u062A\u0628\u0629 \u0642\u064A\u0627\u0633\u064A\u0629: game_3d.noor ---
# \u0645\u0643\u062A\u0628\u0629 \u0645\u062D\u0631\u0643\u0627\u062A \u0627\u0644\u0623\u0644\u0639\u0627\u0628 \u062B\u0644\u0627\u062B\u064A\u0629 \u0627\u0644\u0623\u0628\u0639\u0627\u062F \u0648\u0628\u0631\u0645\u062C\u0629 \u062A\u0637\u0628\u064A\u0642\u0627\u062A \u0627\u0644\u0647\u0648\u0627\u062A\u0641 \u0627\u0644\u0630\u0643\u064A\u0629 (Game 3D & Mobile SDK)
# \u062A\u062A\u064A\u062D \u0643\u062A\u0627\u0628\u0629 \u0623\u0648\u0627\u0645\u0631 \u0644\u0645\u062D\u0631\u0643 \u0646\u0648\u0631 \u0627\u0644\u062F\u0627\u062E\u0644\u064A \u0644\u0644\u062A\u062D\u0643\u0645 \u0641\u064A \u0627\u0644\u0631\u0633\u0648\u0645\u0627\u062A \u0648\u062A\u0635\u062F\u064A\u0631\u0647\u0627

\u0627\u0643\u062A\u0628("\u{1F3AE} \u062A\u0645 \u0627\u0633\u062A\u062F\u0639\u0627\u0621 \u0645\u0643\u062A\u0628\u0629 \u0627\u0644\u0631\u0633\u0648\u0645\u0627\u062A \u0648\u0627\u0644\u0623\u0644\u0639\u0627\u0628 \u0648\u062A\u0637\u0628\u064A\u0642\u0627\u062A \u0627\u0644\u062C\u0648\u0627\u0644 \u0627\u0644\u0633\u0631\u064A\u0639\u0629.")

\u062F\u0627\u0644\u0629 \u0628\u0646\u0627\u0621_\u0644\u0639\u0628\u0629_\u0628\u0637\u0644(\u0627\u0633\u0645_\u0627\u0644\u0644\u0639\u0628\u0629, \u062C\u0648\u062F\u0629_\u0627\u0644\u062C\u0631\u0627\u0641\u064A\u0643) {
  \u0627\u0643\u062A\u0628("-> \u064A\u062A\u0645 \u0627\u0644\u0622\u0646 \u062A\u0647\u064A\u0626\u0629 \u0645\u062D\u0631\u0643 \u0627\u0644\u0623\u0644\u0639\u0627\u0628 \u0627\u0644\u0645\u0633\u062A\u0642\u0644 (Noor3D)... \u0627\u0644\u062C\u0648\u062F\u0629:", \u062C\u0648\u062F\u0629_\u0627\u0644\u062C\u0631\u0627\u0641\u064A\u0643)
  \u0627\u0646\u0634\u0626 \u0627\u0644\u0645\u062D\u0631\u0643 = \u062A\u0647\u064A\u0626\u0629_\u0645\u062D\u0631\u0643()
  
  \u0627\u0646\u0634\u0626 \u0634\u062E\u0635\u064A\u0629 = \u0631\u0633\u0645_\u0645\u062C\u0633\u0645("\u0628\u0637\u0644_\u0634\u062C\u0627\u0639", "\u0646\u0642\u0637\u0629_\u0627\u0644\u0645\u0631\u0643\u0632_0_0")
  \u0627\u0644\u062A\u062D\u0643\u0645_\u0628\u0627\u0644\u0623\u0628\u0639\u0627\u062F(\u0634\u062E\u0635\u064A\u0629, 1.8, 0.5, 0.5)
  
  \u0627\u0646\u0634\u0626 \u0627\u0631\u0636 = \u0631\u0633\u0645_\u0645\u062C\u0633\u0645("\u0633\u0627\u062D\u0629_\u0645\u0639\u0631\u0643\u0629_\u0639\u0634\u0628\u064A\u0629", "\u0627\u0644\u0623\u0633\u0641\u0644_\u0628\u0645\u0633\u062A\u0648\u0649_2")
  \u0627\u0644\u062A\u062D\u0643\u0645_\u0628\u0627\u0644\u0623\u0628\u0639\u0627\u062F(\u0627\u0631\u0636, 100.0, 1.0, 100.0)
  
  \u0627\u0643\u062A\u0628("\u2705 \u062A\u0645 \u0645\u0639\u0627\u0644\u062C\u0629 \u0625\u0636\u0627\u0621\u0627\u062A \u0627\u0644\u0644\u0639\u0628\u0629\u060C \u0627\u0644\u0641\u064A\u0632\u064A\u0627\u0621 \u062C\u0627\u0647\u0632\u0629 120 \u0641\u0631\u064A\u0645.")
  \u0627\u0631\u062C\u0639 \u0627\u0644\u0645\u062D\u0631\u0643
}

\u062F\u0627\u0644\u0629 \u0625\u0635\u062F\u0627\u0631_\u062A\u0637\u0628\u064A\u0642_\u0645\u062A\u0643\u0627\u0645\u0644(\u0645\u0646\u0635\u0629, \u0627\u0633\u0645_\u0627\u0644\u062D\u0632\u0645\u0629) {
  \u0627\u0643\u062A\u0628("\u{1F4F1} \u062C\u0627\u0631\u064A \u062A\u062C\u0645\u064A\u0639 \u0648\u062A\u0631\u062C\u0645\u0629 \u0627\u0644\u0623\u0643\u0648\u0627\u062F \u0627\u0644\u062E\u0627\u0635\u0629 \u0628\u0627\u0644\u0644\u0639\u0628\u0629 \u0644\u0628\u064A\u0626\u0629 \u0627\u0644\u062C\u0648\u0627\u0644 \u0627\u0644\u0645\u0646\u0641\u0635\u0644\u0629:")
  \u0627\u0643\u062A\u0628("   - \u0627\u0633\u0645 \u0627\u0644\u062D\u0632\u0645\u0629 \u0627\u0644\u062A\u0639\u0631\u064A\u0641\u064A:", \u0627\u0633\u0645_\u0627\u0644\u062D\u0632\u0645\u0629)
  
  \u0627\u0646\u0634\u0626 \u0627\u0644\u062A\u062C\u0645\u064A\u0639 = \u062A\u0635\u062F\u064A\u0631_\u0647\u0627\u062A\u0641(\u0645\u0646\u0635\u0629)
  
  \u0627\u0643\u062A\u0628("\u2705 \u0627\u0646\u062A\u0647\u0649 \u0627\u0644\u062A\u062D\u0648\u064A\u0644 \u0627\u0644\u0641\u0648\u0631\u064A. \u062A\u0645 \u0627\u0633\u062A\u062E\u0631\u0627\u062C:", \u0627\u0644\u062A\u062C\u0645\u064A\u0639)
  \u0627\u0631\u062C\u0639 \u0627\u0644\u062A\u062C\u0645\u064A\u0639
}


# --- \u0645\u0643\u062A\u0628\u0629 \u0642\u064A\u0627\u0633\u064A\u0629: graphics.noor ---
# \u0645\u0643\u062A\u0628\u0629 \u0627\u0644\u0631\u0633\u0648\u0645\u064A\u0627\u062A \u0648\u062B\u0646\u0627\u0626\u064A\u0629 \u0627\u0644\u0623\u0628\u0639\u0627\u062F (Noor 2D Graphics & Canvas Library)
# \u062A\u062A\u064A\u062D \u0647\u0630\u0647 \u0627\u0644\u0645\u0643\u062A\u0628\u0629 \u0631\u0633\u0645 \u0623\u0634\u0643\u0627\u0644 \u0647\u0646\u062F\u0633\u064A\u0629\u060C \u0635\u0648\u0631\u060C \u0648\u062E\u0637\u0648\u0637 \u062F\u064A\u0646\u0627\u0645\u064A\u0643\u064A\u0629 \u0639\u0644\u0649 \u0644\u0648\u062D\u0627\u062A \u0627\u0644\u0631\u0633\u0645.

\u0627\u0643\u062A\u0628("\u{1F3A8} \u062A\u0645 \u062A\u062D\u0645\u064A\u0644 \u0645\u0643\u062A\u0628\u0629 \u0627\u0644\u0631\u0633\u0648\u0645\u0627\u062A \u0648\u0627\u0644\u0645\u062D\u0631\u0643 \u0627\u0644\u0647\u0646\u062F\u0633\u064A \u0627\u0644\u062B\u0646\u0627\u0626\u064A \u0627\u0644\u0623\u0628\u0639\u0627\u062F (Noor 2D Engine).")

\u062F\u0627\u0644\u0629 \u0627\u0646\u0634\u0626_\u0644\u0648\u062D\u0629_\u0631\u0633\u0645(\u0627\u0644\u0639\u0631\u0636, \u0627\u0644\u0637\u0648\u0644) {
  \u0627\u0643\u062A\u0628("\u{1F58C}\uFE0F \u062C\u0627\u0631\u064A \u062A\u0647\u064A\u0626\u0629 \u0644\u0648\u062D\u0629 \u0631\u0633\u0645 \u0628\u062F\u0642\u0629:", \u0627\u0644\u0639\u0631\u0636, "x", \u0627\u0644\u0637\u0648\u0644)
  \u0627\u0646\u0634\u0626 \u0644\u0648\u062D\u0629 = { \u0646\u0648\u0639: "canvas", \u0639\u0631\u0636: \u0627\u0644\u0639\u0631\u0636, \u0637\u0648\u0644: \u0627\u0644\u0637\u0648\u0644, \u0639\u0646\u0627\u0635\u0631: [] }
  \u0627\u0631\u062C\u0639 \u0644\u0648\u062D\u0629
}

\u062F\u0627\u0644\u0629 \u0631\u0633\u0645_\u062F\u0627\u0626\u0631\u0629(\u0627\u0644\u0644\u0648\u062D\u0629, \u0633, \u0635, \u0627\u0644\u0642\u0637\u0631, \u0627\u0644\u0644\u0648\u0646) {
  \u0627\u0643\u062A\u0628("\u26AA \u0631\u0633\u0645 \u062F\u0627\u0626\u0631\u0629 \u0641\u064A \u0627\u0644\u0625\u062D\u062F\u0627\u062B\u064A\u0627\u062A (", \u0633, ",", \u0635, ") \u0628\u0642\u0637\u0631", \u0627\u0644\u0642\u0637\u0631, "\u0648\u0644\u0648\u0646", \u0627\u0644\u0644\u0648\u0646)
  \u0627\u0631\u062C\u0639 \u0646\u0639\u0645
}

\u062F\u0627\u0644\u0629 \u0631\u0633\u0645_\u0645\u0633\u062A\u0637\u064A\u0644(\u0627\u0644\u0644\u0648\u062D\u0629, \u0633, \u0635, \u0639\u0631\u0636, \u0637\u0648\u0644, \u0627\u0644\u0644\u0648\u0646) {
  \u0627\u0643\u062A\u0628("\u25AD \u0631\u0633\u0645 \u0645\u0633\u062A\u0637\u064A\u0644 \u0628\u0648\u062C\u0648\u0647 \u062D\u0627\u062F\u0629 \u0648\u0644\u0648\u0646", \u0627\u0644\u0644\u0648\u0646)
  \u0627\u0631\u062C\u0639 \u0646\u0639\u0645
}

\u062F\u0627\u0644\u0629 \u0631\u0633\u0645_\u0646\u0635_\u0645\u062A\u062D\u0631\u0643(\u0627\u0644\u0644\u0648\u062D\u0629, \u0627\u0644\u0646\u0635, \u0633, \u0635, \u0627\u0644\u062E\u0637) {
  \u0627\u0643\u062A\u0628("\u{1F18E} \u0625\u0636\u0627\u0641\u0629 \u0646\u0635 \u062D\u0631\u0643\u064A \u0639\u0644\u0649 \u0627\u0644\u0644\u0648\u062D\u0629:", \u0627\u0644\u0646\u0635)
  \u0627\u0631\u062C\u0639 \u0646\u0639\u0645
}

\u062F\u0627\u0644\u0629 \u062A\u0635\u062F\u064A\u0631_\u0627\u0644\u0644\u0648\u062D\u0629_\u0643\u0635\u0648\u0631\u0629(\u0627\u0644\u0644\u0648\u062D\u0629, \u0627\u0644\u0645\u0633\u0627\u0631) {
  \u0627\u0643\u062A\u0628("\u{1F4BE} \u062A\u0645 \u062D\u0641\u0638 \u0648\u062A\u0635\u062F\u064A\u0631 \u0644\u0648\u062D\u0629 \u0627\u0644\u0631\u0633\u0645 \u0643\u0645\u0644\u0641 \u0635\u0648\u0631\u0629 \u0625\u0644\u0649 \u0627\u0644\u0645\u0633\u0627\u0631:", \u0627\u0644\u0645\u0633\u0627\u0631)
  \u0627\u0631\u062C\u0639 \u0646\u0639\u0645
}


# --- \u0645\u0643\u062A\u0628\u0629 \u0642\u064A\u0627\u0633\u064A\u0629: layouts.noor ---
# \u0645\u0643\u062A\u0628\u0629 \u0642\u0648\u0627\u0644\u0628 \u0627\u0644\u0635\u0641\u062D\u0627\u062A \u0648\u0627\u0644\u062A\u0648\u0632\u064A\u0639\u0627\u062A \u0627\u0644\u0634\u0627\u0645\u0644\u0629 (Noor Sovereign Layouts & Templates)
# \u0635\u0645\u0645\u062A \u0644\u062A\u0648\u0641\u064A\u0631 \u0647\u064A\u0627\u0643\u0644 \u0648\u0627\u0642\u0639\u064A\u0629 \u0644\u0625\u0646\u0634\u0627\u0621 \u0645\u0648\u0627\u0642\u0639 \u0625\u0644\u0643\u062A\u0631\u0648\u0646\u064A\u0629 \u0645\u062A\u0643\u0627\u0645\u0644\u0629 \u0648\u0645\u062A\u0631\u0627\u0628\u0637\u0629 \u0644\u0644\u062A\u0635\u062F\u064A\u0631.

\u0627\u0643\u062A\u0628("\u{1F4D0} \u062A\u0645 \u062A\u062D\u0645\u064A\u0644 \u0645\u0643\u062A\u0628\u0629 \u0627\u0644\u0645\u062E\u0637\u0637\u0627\u062A \u0648\u0627\u0644\u062A\u062E\u0637\u064A\u0637\u0627\u062A \u0627\u0644\u0630\u0643\u064A\u0629 (Noor Layouts v5.0).")

# 1. \u0645\u062E\u0637\u0637 \u0645\u0648\u0642\u0639 \u062A\u0639\u0631\u064A\u0641\u064A \u0644\u0634\u0631\u0643\u0629/\u0645\u0624\u0633\u0633\u0629 \u0628\u0631\u0645\u062C\u064A\u0629 \u0645\u062A\u0637\u0648\u0631\u0629
\u062F\u0627\u0644\u0629 \u0642\u0627\u0644\u0628_\u0645\u0648\u0642\u0639_\u0634\u0631\u0643\u0629_\u062A\u0642\u0646\u064A\u0629(\u0639\u0646\u0648\u0627\u0646_\u0627\u0644\u0645\u0624\u0633\u0633\u0629) {
  \u0627\u0643\u062A\u0628("\u{1F680} \u062C\u0627\u0631\u064A \u0635\u064A\u0627\u063A\u0629 \u0648\u062A\u0631\u0643\u064A\u0628 \u0645\u0648\u0642\u0639 \u0648\u064A\u0628 \u0645\u062A\u0643\u0627\u0645\u0644 \u0644\u0640 \u0634\u0631\u0643\u0629 \u062A\u0642\u0646\u064A\u0629...")
  
  \u0627\u0646\u0634\u0626 \u0635\u0641\u062D\u0629 = \u0647\u064A\u0643\u0644_\u0635\u0641\u062D\u0629(\u0639\u0646\u0648\u0627\u0646_\u0627\u0644\u0645\u0624\u0633\u0633\u0629)
  \u062E\u0644\u0641\u064A\u0629_\u0627\u0644\u0635\u0648\u0631\u0629(\u0635\u0641\u062D\u0629, "\u0623\u0633\u0648\u062F_\u062A\u064A\u062A\u0627\u0646\u064A\u0648\u0645")
  \u062A\u0644\u0648\u064A\u0646_\u0627\u0644\u0646\u0635(\u0635\u0641\u062D\u0629, "\u0633\u0645\u0627\u0648\u064A_\u0628\u0631\u0627\u0642")
  \u062A\u0646\u0633\u064A\u0642_\u0627\u0644\u062E\u0637(\u0635\u0641\u062D\u0629, "Cairo", 24, "\u0639\u0631\u064A\u0636")
  
  \u0625\u0636\u0627\u0641\u0629_\u0646\u0635\u0648\u0635(\u0635\u0641\u062D\u0629, "\u0631\u0623\u0633\u064A\u0629_\u0643\u0628\u064A\u0631\u0629", "\u0627\u0644\u062A\u0645\u064A\u0632 \u0641\u064A \u0627\u0644\u0628\u0646\u064A\u0629 \u0627\u0644\u0628\u0631\u0645\u062C\u064A\u0629 \u0627\u0644\u0645\u0633\u062A\u0642\u0644\u0629 \u{1F48E}")
  \u0625\u0636\u0627\u0641\u0629_\u0646\u0635\u0648\u0635(\u0635\u0641\u062D\u0629, "\u0641\u0642\u0631\u0629", "\u0646\u062D\u0646 \u0646\u0642\u062F\u0645 \u062E\u062F\u0645\u0627\u062A \u0646\u0648\u0639\u064A\u0629 \u0645\u0628\u0631\u0645\u062C\u0629 \u0643\u0644\u064A\u0627\u064B \u0628\u0627\u0644\u0627\u0639\u062A\u0645\u0627\u062F \u0639\u0644\u0649 \u0644\u063A\u0629 \u0646\u0648\u0631 \u0648\u0623\u0646\u0638\u0645\u0629 \u0627\u0644\u0633\u064A\u0627\u062F\u0629 \u0627\u0644\u0631\u0642\u0645\u064A\u0629 \u0627\u0644\u0645\u062A\u0643\u0627\u0645\u0644\u0629.")
  
  \u0628\u0646\u0627\u0621_\u0642\u0627\u0626\u0645\u0629(\u0635\u0641\u062D\u0629, "\u{1F6E0}\uFE0F \u0631\u0643\u0627\u0626\u0632 \u0627\u0644\u062A\u0645\u064A\u0632 \u0648\u0627\u0644\u0633\u064A\u0627\u062F\u0629", ["\u0623\u0645\u0646 \u0645\u062F\u0645\u062C \u0641\u0627\u0626\u0642 \u0627\u0644\u062E\u0635\u0648\u0635\u064A\u0629", "\u0628\u0631\u0645\u062C\u0629 \u0628\u0627\u0644\u0644\u063A\u0629 \u0627\u0644\u0639\u0631\u0628\u064A\u0629 \u0627\u0644\u0645\u0633\u062A\u0642\u0644\u0629", "\u0633\u0631\u0639\u0629 \u0645\u062D\u0627\u0643\u0627\u0629 \u0648\u0627\u0633\u062A\u062C\u0627\u0628\u0629 \u0642\u0635\u0648\u0649"])
  
  \u062A\u0635\u0645\u064A\u0645_\u0646\u0645\u0648\u0630\u062C(\u0635\u0641\u062D\u0629, "\u0627\u062D\u0635\u0644 \u0639\u0644\u0649 \u0627\u0633\u062A\u0634\u0627\u0631\u0629 \u062A\u0642\u0646\u064A\u0629 \u0645\u062C\u0627\u0646\u064A\u0629 \u2709\uFE0F", "consulting@noor.org")
  
  \u0648\u0627\u062C\u0647\u0629_\u0632\u0631(\u0635\u0641\u062D\u0629, "\u0627\u0633\u062A\u0643\u0634\u0627\u0641 \u062E\u062F\u0645\u0627\u062A \u0627\u0644\u0645\u0624\u0633\u0633\u0629 \u0627\u0644\u0628\u0631\u0645\u062C\u064A\u0629")
  
  \u0625\u0636\u0627\u0641\u0629_\u062A\u0623\u062B\u064A\u0631_\u062D\u0631\u0643\u0629(\u0635\u0641\u062D\u0629, "\u062A\u0644\u0627\u0634\u064A_\u062F\u062E\u0648\u0644_\u0645\u0628\u0647\u0631")
  \u0627\u0631\u062C\u0639 \u0635\u0641\u062D\u0629
}

# 2. \u0645\u062E\u0637\u0637 \u0645\u0648\u0642\u0639 \u0627\u0644\u0633\u064A\u0631\u0629 \u0627\u0644\u0630\u0627\u062A\u064A\u0629 \u0648\u0645\u0639\u0631\u0636 \u0627\u0644\u0623\u0639\u0645\u0627\u0644 \u0627\u0644\u0634\u062E\u0635\u064A
\u062F\u0627\u0644\u0629 \u0642\u0627\u0644\u0628_\u0645\u0639\u0631\u0636_\u0623\u0639\u0645\u0627\u0644_\u0645\u0637\u0648\u0631(\u0627\u0633\u0645_\u0627\u0644\u0645\u0637\u0648\u0631) {
  \u0627\u0643\u062A\u0628("\u{1F680} \u062C\u0627\u0631\u064A \u0635\u064A\u0627\u063A\u0629 \u0648\u062A\u0631\u0643\u064A\u0628 \u0645\u0639\u0631\u0636 \u0623\u0639\u0645\u0627\u0644 \u0634\u062E\u0635\u064A \u0644\u0644\u0645\u0637\u0648\u0631...")
  
  \u0627\u0646\u0634\u0626 \u0635\u0641\u062D\u0629 = \u0647\u064A\u0643\u0644_\u0635\u0641\u062D\u0629(\u0627\u0633\u0645_\u0627\u0644\u0645\u0637\u0648\u0631)
  \u062E\u0644\u0641\u064A\u0629_\u0627\u0644\u0635\u0648\u0631\u0629(\u0635\u0641\u062D\u0629, "\u0628\u0646\u0641\u0633\u062C\u064A_\u0645\u0638\u0644\u0645")
  \u062A\u0644\u0648\u064A\u0646_\u0627\u0644\u0646\u0635(\u0635\u0641\u062D\u0629, "\u0630\u0647\u0628\u064A_\u0641\u062E\u0645")
  \u062A\u0646\u0633\u064A\u0642_\u0627\u0644\u062E\u0637(\u0635\u0641\u062D\u0629, "Tajawal", 22, "\u0639\u0627\u0644\u064A")
  
  \u0625\u0636\u0627\u0641\u0629_\u0646\u0635\u0648\u0635(\u0635\u0641\u062D\u0629, "\u0631\u0623\u0633\u064A\u0629_\u0643\u0628\u064A\u0631\u0629", "\u0645\u0639\u0631\u0636 \u0623\u0639\u0645\u0627\u0644 \u0648\u0645\u0634\u0627\u0631\u064A\u0639 \u0627\u0644\u0645\u0628\u062F\u0639 \u2728")
  \u0625\u0636\u0627\u0641\u0629_\u0646\u0635\u0648\u0635(\u0635\u0641\u062D\u0629, "\u0641\u0642\u0631\u0629", "\u0645\u0631\u062D\u0628\u0627\u064B \u0628\u0643\u0645! \u0623\u0646\u0627 \u0645\u0647\u0646\u062F\u0633 \u0628\u0631\u0645\u062C\u064A\u0627\u062A \u0645\u0633\u062A\u0642\u0644 \u0645\u062E\u062A\u0635 \u0641\u064A \u0628\u0646\u0627\u0621 \u0627\u0644\u0646\u0638\u0645 \u0627\u0644\u0645\u0648\u0632\u0639\u0629 \u0648\u0627\u0644\u0645\u0648\u0627\u0642\u0639 \u0627\u0644\u0625\u0644\u0643\u062A\u0631\u0648\u0646\u064A\u0629 \u0627\u0644\u0641\u0627\u062E\u0631\u0629.")
  
  \u0627\u0646\u0634\u0626 \u0643\u062A\u0644_\u0627\u0644\u062C\u062F\u0648\u0644 = \u062A\u0635\u0645\u064A\u0645_\u062C\u062F\u0648\u0644(\u0635\u0641\u062D\u0629, ["\u0627\u0633\u0645 \u0627\u0644\u0645\u0634\u0631\u0648\u0639", "\u0627\u0644\u062A\u0642\u0646\u064A\u0629 \u0627\u0644\u0645\u0633\u062A\u0639\u0645\u0644\u0629", "\u062D\u0627\u0644\u0629 \u0627\u0644\u0625\u0646\u062A\u0627\u062C"])
  \u0627\u0636\u0641_\u0635\u0641_\u062C\u062F\u0648\u0644(\u0643\u062A\u0644_\u0627\u0644\u062C\u062F\u0648\u0644, ["\u0646\u0638\u0627\u0645 \u062A\u0634\u0641\u064A\u0631 \u0646\u0648\u0631 \u0627\u0644\u0633\u064A\u0627\u062F\u064A", "Noor Core OS", "\u0645\u0643\u062A\u0645\u0644 \u0648\u064A\u062D\u0627\u0643\u064A"])
  \u0627\u0636\u0641_\u0635\u0641_\u062C\u062F\u0648\u0644(\u0643\u062A\u0644_\u0627\u0644\u062C\u062F\u0648\u0644, ["\u0645\u0646\u0635\u0629 \u062A\u0633\u0648\u0642 \u0628\u0627\u0644\u0630\u0643\u0627\u0621 \u0627\u0644\u0627\u0635\u0637\u0646\u0627\u0639\u064A", "PyNoor ML", "\u062A\u062D\u062A \u0627\u0644\u062A\u0637\u0648\u064A\u0631 \u0627\u0644\u0645\u062A\u0642\u062F\u0645"])
  
  \u062A\u0635\u0645\u064A\u0645_\u0646\u0645\u0648\u0630\u062C(\u0635\u0641\u062D\u0629, "\u0623\u0631\u0633\u0644 \u0644\u064A \u0639\u0631\u0636 \u0639\u0645\u0644 \u0623\u0648 \u0634\u0631\u0627\u0643\u0629 \u0628\u0631\u0645\u062C\u064A\u0629 \u{1F4E9}", "developer@cairo-sovereign.net")
  
  \u062A\u0648\u062C\u064A\u0647_\u0631\u0627\u0628\u0637(\u0635\u0641\u062D\u0629, "https://github.com/noor-sovereign", "\u0631\u0627\u0628\u0637 \u0641\u062D\u0635 \u0627\u0644\u0643\u0648\u062F \u0627\u0644\u0645\u0635\u062F\u0631\u064A \u0627\u0644\u0623\u0635\u0644\u064A")
  
  \u0627\u0631\u062C\u0639 \u0635\u0641\u062D\u0629
}

# 3. \u0645\u062E\u0637\u0637 \u0645\u0646\u0635\u0629 \u0627\u0644\u062E\u062F\u0645\u0627\u062A \u0648\u0627\u0644\u062A\u0633\u0639\u064A\u0631 \u0627\u0644\u062A\u062C\u0627\u0631\u064A \u0627\u0644\u0633\u0631\u064A\u0639
\u062F\u0627\u0644\u0629 \u0642\u0627\u0644\u0628_\u0628\u0648\u0627\u0628\u0629_\u0627\u0634\u062A\u0631\u0627\u0643\u0627\u062A_\u0633\u062D\u0627\u0628\u064A\u0629(\u0627\u0633\u0645_\u0627\u0644\u0645\u0646\u0635\u0629) {
  \u0627\u0643\u062A\u0628("\u{1F680} \u062C\u0627\u0631\u064A \u0635\u064A\u0627\u063A\u0629 \u0648\u062A\u0631\u0643\u064A\u0628 \u0628\u0648\u0627\u0628\u0629 \u0627\u0634\u062A\u0631\u0627\u0643\u0627\u062A \u0648\u062D\u062C\u0648\u0632\u0627\u062A \u062A\u062C\u0627\u0631\u064A\u0629...")
  
  \u0627\u0646\u0634\u0626 \u0635\u0641\u062D\u0629 = \u0647\u064A\u0643\u0644_\u0635\u0641\u062D\u0629(\u0627\u0633\u0645_\u0645\u0646\u0635\u0629)
  \u062E\u0644\u0641\u064A\u0629_\u0627\u0644\u0635\u0648\u0631\u0629(\u0635\u0641\u062D\u0629, "\u063A\u0631\u0648\u0628_\u0627\u0644\u0634\u0645\u0633")
  \u062A\u0644\u0648\u064A\u0646_\u0627\u0644\u0646\u0635(\u0635\u0641\u062D\u0629, "\u0648\u0631\u062F\u064A")
  
  \u0625\u0636\u0627\u0641\u0629_\u0646\u0635\u0648\u0635(\u0635\u0641\u062D\u0629, "\u0631\u0623\u0633\u064A\u0629_\u0643\u0628\u064A\u0631\u0629", "\u0628\u0648\u0627\u0628\u0629 \u0627\u0644\u062E\u062F\u0645\u0627\u062A \u0627\u0644\u0633\u062D\u0627\u0628\u064A\u0629 \u0627\u0644\u0645\u0634\u062A\u0631\u0643\u0629 \u2601\uFE0F")
  \u0625\u0636\u0627\u0641\u0629_\u0646\u0635\u0648\u0635(\u0635\u0641\u062D\u0629, "\u0641\u0642\u0631\u0629", "\u0627\u062E\u062A\u0631 \u0627\u0644\u0628\u0627\u0642\u0629 \u0627\u0644\u0645\u0646\u0627\u0633\u0628\u0629 \u0644\u0645\u0624\u0633\u0633\u062A\u0643 \u0648\u0627\u0628\u062F\u0623 \u0645\u0633\u064A\u0631\u0629 \u0627\u0644\u0633\u064A\u0627\u062F\u0629 \u0627\u0644\u0631\u0642\u0645\u064A\u0629 \u0648\u062A\u0648\u0633\u0639\u0629 \u062E\u0648\u0627\u062F\u0645 \u0646\u0648\u0631 \u0627\u0644\u0627\u0641\u062A\u0631\u0627\u0636\u064A\u0629 \u0627\u0644\u0622\u0646.")
  
  \u0627\u0646\u0634\u0626 \u0627\u0644\u0639\u0631\u0648\u0636 = \u062A\u0635\u0645\u064A\u0645_\u062C\u062F\u0648\u0644(\u0635\u0641\u062D\u0629, ["\u0627\u0633\u0645 \u0627\u0644\u0628\u0627\u0642\u0629 \u0627\u0644\u062A\u062C\u0627\u0631\u064A\u0629", "\u0627\u0644\u062D\u0634\u062F \u0627\u0644\u0633\u062D\u0627\u0628\u064A", "\u0627\u0644\u062A\u0643\u0644\u0641\u0629 \u0627\u0644\u0633\u0646\u0648\u064A\u0629"])
  \u0627\u0636\u0641_\u0635\u0641_\u062C\u062F\u0648\u0644(\u0627\u0644\u0639\u0631\u0648\u0636, ["\u0628\u0627\u0642\u0629 \u0627\u0644\u0647\u0648\u0627\u0629 \u0627\u0644\u0645\u0633\u062A\u0642\u0644\u064A\u0646", "10 \u062E\u0648\u0627\u062F\u0645 \u0627\u0641\u062A\u0631\u0627\u0636\u064A\u0629", "150 \u062F\u0648\u0644\u0627\u0631"])
  \u0627\u0636\u0641_\u0635\u0641_\u062C\u062F\u0648\u0644(\u0627\u0644\u0639\u0631\u0648\u0636, ["\u0628\u0627\u0642\u0629 \u0627\u0644\u0633\u064A\u0627\u062F\u0629 \u0627\u0644\u0643\u0627\u0645\u0644\u0629", "\u062E\u0648\u0627\u062F\u0645 \u063A\u064A\u0631 \u0645\u062D\u062F\u0648\u062F\u0629 + \u062F\u0639\u0645 \u0645\u062E\u0635\u0635", "990 \u062F\u0648\u0644\u0627\u0631"])
  
  \u0648\u0627\u062C\u0647\u0629_\u0632\u0631(\u0635\u0641\u062D\u0629, "\u0625\u0646\u0634\u0627\u0621 \u062D\u0633\u0627\u0628 \u062A\u062C\u0627\u0631\u064A \u062C\u062F\u064A\u062F \u0644\u0644\u062A\u062D\u0643\u0645 \u0628\u0627\u0644\u0628\u0627\u0642\u0627\u062A")
  
  \u0627\u0631\u062C\u0639 \u0635\u0641\u062D\u0629
}


# --- \u0645\u0643\u062A\u0628\u0629 \u0642\u064A\u0627\u0633\u064A\u0629: network.noor ---
# \u0645\u0643\u062A\u0628\u0629 \u0627\u0644\u062E\u0648\u0627\u062F\u0645 \u0648\u062A\u0637\u0648\u064A\u0631 \u0648\u0627\u062C\u0647\u0627\u062A \u0627\u0644\u0628\u0631\u0645\u062C\u0629 (APIs / Web Servers)
# \u062A\u062D\u062A\u0648\u064A \u0639\u0644\u0649 \u0643\u0648\u062F \u0644\u063A\u0629 \u0646\u0648\u0631 \u0627\u0644\u062C\u0627\u0647\u0632 \u0644\u062A\u0635\u0645\u064A\u0645 \u0627\u0644\u062E\u0648\u0627\u062F\u0645 \u0627\u0644\u0645\u0633\u062A\u0642\u0644\u0629 

\u062F\u0627\u0644\u0629 \u0625\u0637\u0644\u0627\u0642_\u0633\u064A\u0631\u0641\u0631_\u0645\u062A\u0637\u0648\u0631(\u0627\u0644\u0645\u0646\u0641\u0630, \u0627\u0633\u0645_\u0627\u0644\u062E\u0627\u062F\u0645) {
  \u0627\u0643\u062A\u0628("\u{1F680} \u0628\u062F\u0621 \u0625\u0637\u0644\u0627\u0642 \u0633\u064A\u0631\u0641\u0631 \u0645\u062A\u0637\u0648\u0631 \u0628\u062E\u0635\u0627\u0626\u0635 WebSockets \u0648 Cluster Node.")
  \u0627\u0646\u0634\u0626 \u0627\u0644\u0633\u064A\u0631\u0641\u0631 = \u0627\u0646\u0634\u0626_\u0633\u064A\u0631\u0641\u0631(\u0627\u0644\u0645\u0646\u0641\u0630)
  \u0627\u0643\u062A\u0628("- \u0627\u0633\u0645 \u0627\u0644\u0633\u064A\u0631\u0641\u0631 \u0627\u0644\u0646\u0634\u0637:", \u0627\u0633\u0645_\u0627\u0644\u062E\u0627\u062F\u0645)
  \u0627\u0643\u062A\u0628("- \u0627\u0644\u0645\u0646\u0641\u0630:", \u0627\u0644\u0645\u0646\u0641\u0630)
  \u0627\u0643\u062A\u0628("- \u062D\u0627\u0644\u0629 \u0627\u062A\u0635\u0627\u0644 \u0642\u0648\u0627\u0639\u062F \u0627\u0644\u0628\u064A\u0627\u0646\u0627\u062A DB: \u062C\u0627\u0647\u0632\u0629")
  \u0627\u064A\u062F\u0627\u0639_\u0627\u0644\u0623\u0648\u0627\u0645\u0631(\u0627\u0644\u0633\u064A\u0631\u0641\u0631)
  \u0627\u0631\u062C\u0639 \u0627\u0644\u0633\u064A\u0631\u0641\u0631
}

\u062F\u0627\u0644\u0629 \u0627\u064A\u062F\u0627\u0639_\u0627\u0644\u0623\u0648\u0627\u0645\u0631(\u0627\u0644\u0633\u064A\u0631\u0641\u0631) {
  # \u0623\u062A\u0645\u062A\u0629 \u0645\u0647\u0627\u0645 \u0627\u0644\u0633\u064A\u0631\u0641\u0631\u0627\u062A \u0648\u0623\u0646\u0638\u0645\u0629 \u0627\u0644\u062D\u0645\u0627\u064A\u0629
  \u0627\u0646\u0634\u0626 \u062C\u062F\u0627\u0631_\u0646\u0627\u0631\u064A = \u0627\u0639\u062F\u0627\u062F\u0627\u062A_\u0627\u0644\u0646\u0638\u0627\u0645("FIREWALL", "ON")
  \u0627\u0643\u062A\u0628("- \u062A\u0645 \u062A\u0641\u0639\u064A\u0644 \u062C\u062F\u0627\u0631 \u0627\u0644\u062D\u0645\u0627\u064A\u0629 (Firewall) \u0644\u0644\u062E\u0627\u062F\u0645 \u0644\u0645\u0646\u0639 \u0627\u0644\u0647\u062C\u0645\u0627\u062A \u0627\u0644\u0645\u0648\u0632\u0639\u0629 DDoS.")
}


# --- \u0645\u0643\u062A\u0628\u0629 \u0642\u064A\u0627\u0633\u064A\u0629: sockets_client.noor ---
# \u0645\u0643\u062A\u0628\u0629 \u0627\u062A\u0635\u0627\u0644\u0627\u062A \u0627\u0644\u0645\u0642\u0627\u0628\u0633 \u0627\u0644\u062E\u0627\u0631\u062C\u064A\u0629 \u0648\u0645\u0648\u0635\u0644\u0627\u062A \u0627\u0644\u0648\u064A\u0628 \u0627\u0644\u062D\u064A\u0629 (Sockets & Live Web API Connectors)
# \u062A\u062F\u0639\u0645 \u0627\u0644\u062A\u062E\u0627\u0637\u0628 \u0627\u0644\u062D\u064A \u0645\u0639 \u0627\u0644\u0631\u0648\u0627\u0641\u062F \u0648\u0627\u0644\u0645\u0646\u0635\u0627\u062A \u0627\u0644\u0633\u062D\u0627\u0628\u064A\u0629 \u0627\u0644\u062D\u0642\u064A\u0642\u064A\u0629

\u0627\u0643\u062A\u0628("\u{1F310} \u062A\u0645 \u0627\u0633\u062A\u064A\u0631\u0627\u062F \u0645\u0643\u062A\u0628\u0629 \u0627\u0644\u0631\u0648\u0627\u0628\u0637 \u0627\u0644\u0634\u0628\u0643\u064A\u0629 \u0627\u0644\u062D\u064A\u0629 \u0648\u0627\u0644\u0645\u0642\u0627\u0628\u0633 \u0627\u0644\u0633\u064A\u0627\u062F\u064A\u0629.")

\u062F\u0627\u0644\u0629 \u062C\u0644\u0628_\u0628\u064A\u0627\u0646\u0627\u062A_\u0645\u0648\u0642\u0639_\u062D\u0642\u064A\u0642\u064A(\u0627\u0644\u0631\u0627\u0628\u0637) {
  \u0627\u0643\u062A\u0628("\u{1F310} \u062C\u0627\u0631\u064A \u0637\u0644\u0628 \u0627\u062A\u0635\u0627\u0644 \u062D\u0642\u064A\u0642\u064A \u0648\u0622\u0645\u0646 \u0628\u0627\u0644\u0625\u0646\u062A\u0631\u0646\u062A...")
  \u0627\u0646\u0634\u0626 \u0627\u0644\u0627\u0633\u062A\u062C\u0627\u0628\u0629 = \u0637\u0644\u0628_\u0648\u064A\u0628_\u0641\u0639\u0644\u064A\u0629(\u0627\u0644\u0631\u0627\u0628\u0637)
  \u0627\u0631\u062C\u0639 \u0627\u0644\u0627\u0633\u062A\u062C\u0627\u0628\u0629
}

\u062F\u0627\u0644\u0629 \u0641\u062A\u062D_\u0645\u0642\u0628\u0633_\u0648\u064A\u0628_\u062D\u064A(\u0627\u0644\u0639\u0646\u0648\u0627\u0646) {
  \u0627\u0643\u062A\u0628("\u{1F50C} \u062C\u0627\u0631\u064A \u0625\u062C\u0631\u0627\u0621 \u0645\u0635\u0627\u0641\u062D\u0629 \u062B\u0646\u0627\u0626\u064A\u0629 \u0645\u0643\u0627\u0645\u0644\u0629 (Handshake) \u0644\u0641\u062A\u062D \u0645\u0642\u0628\u0633 \u0648\u064A\u0628...")
  \u0627\u0646\u0634\u0626 \u0646\u0627\u062A\u062C = \u0627\u062A\u0635\u0627\u0644_\u0645\u0642\u0627\u0628\u0633(\u0627\u0644\u0639\u0646\u0648\u0627\u0646)
  \u0627\u0630\u0627 (\u0646\u0627\u062A\u062C == \u0635\u062D\u064A\u062D) {
    \u0627\u0643\u062A\u0628("\u2705 \u062A\u0645 \u0641\u062A\u062D \u0627\u0644\u0627\u062A\u0635\u0627\u0644 \u0641\u064A \u0627\u0644\u0648\u0642\u062A \u0627\u0644\u0641\u0639\u0644\u064A \u0645\u0639 \u0627\u0644\u0633\u064A\u0631\u0641\u0631 \u0627\u0644\u0633\u062D\u0627\u0628\u064A:", \u0627\u0644\u0639\u0646\u0648\u0627\u0646)
  }
  \u0627\u0631\u062C\u0639 \u0646\u0627\u062A\u062C
}


# --- \u0645\u0643\u062A\u0628\u0629 \u0642\u064A\u0627\u0633\u064A\u0629: testing.noor ---
# \u0645\u0643\u062A\u0628\u0629 \u0627\u0644\u0627\u062E\u062A\u0628\u0627\u0631 \u0648\u062A\u0648\u0643\u064A\u062F \u0627\u0644\u062C\u0648\u062F\u0629 (Noor Unit Testing & QA Library)
# \u062A\u062A\u064A\u062D \u0644\u0644\u0645\u0637\u0648\u0631\u064A\u0646 \u0643\u062A\u0627\u0628\u0629 \u0627\u062E\u062A\u0628\u0627\u0631\u0627\u062A \u0647\u064A\u0643\u0644\u064A\u0629 \u0644\u0644\u062A\u0623\u0643\u062F \u0645\u0646 \u0633\u0644\u0627\u0645\u0629 \u0627\u0644\u0623\u0643\u0648\u0627\u062F \u0648\u0627\u0644\u0645\u0646\u0637\u0642.

\u0627\u0643\u062A\u0628("\u{1F9EA} \u062A\u0645 \u062A\u0641\u0639\u064A\u0644 \u0648\u062D\u062F\u0629 \u0627\u062E\u062A\u0628\u0627\u0631 \u0627\u0644\u0643\u0648\u062F (Noor Testing Framework).")

\u062F\u0627\u0644\u0629 \u0627\u062E\u062A\u0628\u0627\u0631_\u0627\u0644\u062A\u0637\u0627\u0628\u0642(\u0627\u0644\u0646\u062A\u064A\u062C\u0629_\u0627\u0644\u0645\u062A\u0648\u0642\u0639\u0629, \u0627\u0644\u0646\u062A\u064A\u062C\u0629_\u0627\u0644\u0641\u0639\u0644\u064A\u0629, \u0627\u0633\u0645_\u0627\u0644\u0627\u062E\u062A\u0628\u0627\u0631) {
  \u0627\u0630\u0627 (\u0627\u0644\u0646\u062A\u064A\u062C\u0629_\u0627\u0644\u0645\u062A\u0648\u0642\u0639\u0629 == \u0627\u0644\u0646\u062A\u064A\u062C\u0629_\u0627\u0644\u0641\u0639\u0644\u064A\u0629) {
    \u0627\u0643\u062A\u0628("\u2705 \u0646\u062C\u0627\u062D \u0627\u0644\u0627\u062E\u062A\u0628\u0627\u0631:", \u0627\u0633\u0645_\u0627\u0644\u0627\u062E\u062A\u0628\u0627\u0631)
    \u0627\u0631\u062C\u0639 \u0646\u0639\u0645
  } \u0627\u062E\u0631 {
    \u0645\u0639\u0627\u0644\u062C\u0629_\u062E\u0637\u0623("\u274C \u0641\u0634\u0644 \u0627\u0644\u0627\u062E\u062A\u0628\u0627\u0631: " + \u0627\u0633\u0645_\u0627\u0644\u0627\u062E\u062A\u0628\u0627\u0631 + " - \u0627\u0644\u0646\u062A\u064A\u062C\u0629 \u0644\u0627 \u062A\u062A\u0637\u0627\u0628\u0642.")
    \u0627\u0631\u062C\u0639 \u0644\u0627
  }
}

\u062F\u0627\u0644\u0629 \u0627\u062E\u062A\u0628\u0627\u0631_\u0639\u062F\u0645_\u0627\u0644\u062A\u0637\u0627\u0628\u0642(\u0627\u0644\u0646\u062A\u064A\u062C\u0629_\u0627\u0644\u0645\u0631\u0641\u0648\u0636\u0629, \u0627\u0644\u0646\u062A\u064A\u062C\u0629_\u0627\u0644\u0641\u0639\u0644\u064A\u0629, \u0627\u0633\u0645_\u0627\u0644\u0627\u062E\u062A\u0628\u0627\u0631) {
  \u0627\u0630\u0627 (\u0627\u0644\u0646\u062A\u064A\u062C\u0629_\u0627\u0644\u0645\u0631\u0641\u0648\u0636\u0629 != \u0627\u0644\u0646\u062A\u064A\u062C\u0629_\u0627\u0644\u0641\u0639\u0644\u064A\u0629) {
    \u0627\u0643\u062A\u0628("\u2705 \u0646\u062C\u0627\u062D \u0627\u0644\u0627\u062E\u062A\u0628\u0627\u0631 \u0627\u0644\u0639\u0643\u0633\u064A:", \u0627\u0633\u0645_\u0627\u0644\u0627\u062E\u062A\u0628\u0627\u0631)
    \u0627\u0631\u062C\u0639 \u0646\u0639\u0645
  } \u0627\u062E\u0631 {
    \u0645\u0639\u0627\u0644\u062C\u0629_\u062E\u0637\u0623("\u274C \u0641\u0634\u0644 \u0627\u0644\u0627\u062E\u062A\u0628\u0627\u0631: " + \u0627\u0633\u0645_\u0627\u0644\u0627\u062E\u062A\u0628\u0627\u0631 + " - \u0627\u0644\u0646\u062A\u064A\u062C\u0629 \u064A\u062C\u0628 \u0623\u0644\u0627 \u062A\u062A\u0637\u0627\u0628\u0642.")
    \u0627\u0631\u062C\u0639 \u0644\u0627
  }
}

\u062F\u0627\u0644\u0629 \u062A\u0634\u063A\u064A\u0644_\u0643\u0644_\u0627\u0644\u0627\u062E\u062A\u0628\u0627\u0631\u0627\u062A(\u0642\u0627\u0626\u0645\u0629_\u0627\u0644\u0627\u062E\u062A\u0628\u0627\u0631\u0627\u062A) {
  \u0627\u0643\u062A\u0628("\u{1F680} \u062C\u0627\u0631\u064A \u0641\u062D\u0635 \u0648\u062A\u0634\u063A\u064A\u0644 \u062D\u0632\u0645\u0629 \u0627\u0644\u0627\u062E\u062A\u0628\u0627\u0631\u0627\u062A \u0627\u0644\u0634\u0627\u0645\u0644\u0629 \u0627\u0644\u0645\u0639\u062A\u0645\u062F\u0629...")
  # \u064A\u062A\u0645 \u0627\u0644\u0645\u0631\u0648\u0631 \u0639\u0644\u0649 \u0627\u0644\u0645\u0635\u0641\u0648\u0641\u0627\u062A \u0648\u062A\u0634\u063A\u064A\u0644\u0647\u0627
  \u0627\u0643\u062A\u0628("\u{1F3C6} \u0623\u062A\u0645\u062A \u0645\u0646\u0635\u0629 \u0646\u0648\u0631 \u0627\u062E\u062A\u0628\u0627\u0631 \u0648\u062A\u0634\u063A\u064A\u0644 \u062C\u0645\u064A\u0639 \u0627\u0644\u0643\u062A\u0644 \u0627\u0644\u0628\u0631\u0645\u062C\u064A\u0629 \u0628\u0646\u062C\u0627\u062D.")
  \u0627\u0631\u062C\u0639 \u0646\u0639\u0645
}


# --- \u0645\u0643\u062A\u0628\u0629 \u0642\u064A\u0627\u0633\u064A\u0629: ui_components.noor ---
# \u0645\u0643\u062A\u0628\u0629 \u0627\u0644\u0645\u0643\u0648\u0646\u0627\u062A \u0648\u0627\u0644\u0639\u0646\u0627\u0635\u0631 \u0627\u0644\u062C\u0627\u0647\u0632\u0629 \u0644\u0640 \u0644\u063A\u0629 \u0646\u0648\u0631 (Noor UI Components Library)
# \u062A\u0648\u0641\u0631 \u0647\u0630\u0647 \u0627\u0644\u0645\u0643\u062A\u0628\u0629 \u0642\u0648\u0627\u0644\u0628 \u0645\u0643\u0648\u0646\u0627\u062A \u0645\u0633\u0628\u0642\u0629 \u0627\u0644\u0628\u0631\u0645\u062C\u0629 \u0644\u062A\u0633\u0647\u064A\u0644 \u0639\u0645\u0644\u064A\u0629 \u0627\u0644\u062A\u0635\u0645\u064A\u0645 \u0648\u0627\u0644\u062A\u0631\u0643\u064A\u0628 \u0627\u0644\u0633\u0631\u064A\u0639.

\u0627\u0643\u062A\u0628("\u{1F9E9} \u062A\u0645 \u0627\u0633\u062A\u062F\u0639\u0627\u0621 \u0645\u0643\u062A\u0628\u0629 \u0627\u0644\u0645\u0643\u0648\u0646\u0627\u062A \u0627\u0644\u062A\u0641\u0627\u0639\u0644\u064A\u0629 \u0648\u0627\u0644\u0646\u0645\u0627\u0630\u062C \u0627\u0644\u062C\u0627\u0647\u0632\u0629 \u0644\u0640 (Noor UI Kit v5.0).")

# 1. \u062A\u0635\u0645\u064A\u0645 \u062A\u0631\u0648\u064A\u0633\u0629 \u0631\u0626\u064A\u0633\u064A\u0629 \u062C\u0630\u0627\u0628\u0629 (Hero Section)
\u062F\u0627\u0644\u0629 \u0648\u0627\u062C\u0647\u0629_\u0627\u0644\u062A\u0631\u0648\u064A\u0633\u0629_\u0627\u0644\u0630\u0647\u0628\u064A\u0629(\u0627\u0644\u0635\u0641\u062D\u0629, \u0627\u0644\u0639\u0646\u0648\u0627\u0646_\u0627\u0644\u0631\u0627\u0626\u0639, \u0627\u0644\u0648\u0635\u0641_\u0627\u0644\u0645\u0648\u062C\u0632) {
  \u0627\u0643\u062A\u0628("\u2728 \u062C\u0627\u0631\u064A \u0625\u062F\u0631\u0627\u062C \u0642\u0633\u0645 \u0627\u0644\u062A\u0631\u062D\u064A\u0628 \u0627\u0644\u0631\u0626\u064A\u0633\u064A \u0627\u0644\u0645\u062A\u0645\u064A\u0632...")
  \u0625\u0636\u0627\u0641\u0629_\u0646\u0635\u0648\u0635(\u0627\u0644\u0635\u0641\u062D\u0629, "\u0631\u0623\u0633\u064A\u0629_\u0643\u0628\u064A\u0631\u0629", \u0627\u0644\u0639\u0646\u0648\u0627\u0646_\u0627\u0644\u0631\u0627\u0626\u0639)
  \u0625\u0636\u0627\u0641\u0629_\u0646\u0635\u0648\u0635(\u0627\u0644\u0635\u0641\u062D\u0629, "\u0641\u0642\u0631\u0629", \u0627\u0644\u0648\u0635\u0641_\u0627\u0644\u0645\u0648\u062C\u0632)
  \u0627\u0631\u062C\u0639 \u0646\u0639\u0645
}

# 2. \u0625\u0646\u0634\u0627\u0621 \u0642\u0627\u0626\u0645\u0629 \u062E\u062F\u0645\u0627\u062A/\u0645\u064A\u0632\u0627\u062A \u0641\u0631\u064A\u062F\u0629
\u062F\u0627\u0644\u0629 \u0642\u0627\u0626\u0645\u0629_\u0627\u0644\u0645\u0632\u0627\u064A\u0627_\u0627\u0644\u0631\u0627\u0626\u0639\u0629(\u0627\u0644\u0635\u0641\u062D\u0629, \u0639\u0646\u0648\u0627\u0646_\u0627\u0644\u0642\u0633\u0645, \u0627\u0644\u0645\u064A\u0632\u0627\u062A_\u0627\u0644\u0645\u0631\u062A\u0628\u0629) {
  \u0627\u0643\u062A\u0628("\u2728 \u062C\u0627\u0631\u064A \u062A\u0646\u0633\u064A\u0642 \u0648\u0628\u0646\u0627\u0621 \u0642\u0627\u0626\u0645\u0629 \u0645\u0645\u064A\u0632\u0627\u062A \u0645\u062A\u0643\u0627\u0645\u0644\u0629...")
  \u0625\u0636\u0627\u0641\u0629_\u0646\u0635\u0648\u0635(\u0627\u0644\u0635\u0641\u062D\u0629, "\u0639\u0646\u0648\u0627\u0646", \u0639\u0646\u0648\u0627\u0646_\u0627\u0644\u0642\u0633\u0645)
  \u0627\u0646\u0634\u0626 \u0627\u0644\u0642\u0627\u0626\u0645\u0629 = \u0628\u0646\u0627\u0621_\u0642\u0627\u0626\u0645\u0629(\u0627\u0644\u0635\u0641\u062D\u0629, "\u{1F4CB} \u0623\u0647\u0645 \u0627\u0644\u0645\u0632\u0627\u064A\u0627 \u0648\u0627\u0644\u0645\u0645\u064A\u0632\u0627\u062A \u0627\u0644\u062A\u0642\u0646\u064A\u0629", \u0627\u0644\u0645\u064A\u0632\u0627\u062A_\u0627\u0644\u0645\u0631\u062A\u0628\u0629)
  \u0627\u0631\u062C\u0639 \u0627\u0644\u0642\u0627\u0626\u0645\u0629
}

# 3. \u0625\u0639\u062F\u0627\u062F \u062C\u062F\u0648\u0644 \u0627\u0644\u0623\u0633\u0639\u0627\u0631 \u0648\u0627\u0644\u0639\u0631\u0648\u0636 \u0627\u0644\u062A\u062C\u0627\u0631\u064A\u0629
\u062F\u0627\u0644\u0629 \u062C\u062F\u0648\u0644_\u0628\u0627\u0642\u0627\u062A_\u0627\u0644\u0623\u0633\u0639\u0627\u0631(\u0627\u0644\u0635\u0641\u062D\u0629, \u0627\u0644\u0623\u0639\u0645\u062F\u0629_\u0627\u0644\u0623\u0633\u0627\u0633\u064A\u0629, \u0628\u0627\u0642\u0629_\u0627\u0644\u0641\u0636\u064A, \u0628\u0627\u0642\u0629_\u0627\u0644\u0630\u0647\u0628\u064A) {
  \u0627\u0643\u062A\u0628("\u2728 \u062C\u0627\u0631\u064A \u062A\u0635\u0645\u064A\u0645 \u062C\u062F\u0648\u0644 \u0645\u0635\u0641\u0648\u0641\u0629 \u0627\u0644\u0623\u0633\u0639\u0627\u0631 \u0648\u0627\u0644\u062E\u062F\u0645\u0627\u062A \u0627\u0644\u0645\u062A\u062C\u0627\u0648\u0628\u0629...")
  \u0627\u0646\u0634\u0626 \u0627\u0644\u062C\u062F\u0648\u0644 = \u062A\u0635\u0645\u064A\u0645_\u062C\u062F\u0648\u0644(\u0627\u0644\u0635\u0641\u062D\u0629, \u0627\u0644\u0623\u0639\u0645\u062F\u0629_\u0627\u0644\u0623\u0633\u0627\u0633\u064A\u0629)
  \u0627\u0636\u0641_\u0635\u0641_\u062C\u062F\u0648\u0644(\u0627\u0644\u062C\u062F\u0648\u0644, \u0628\u0627\u0642\u0629_\u0627\u0644\u0641\u0636\u064A)
  \u0627\u0636\u0641_\u0635\u0641_\u062C\u062F\u0648\u0644(\u0627\u0644\u062C\u062F\u0648\u0644, \u0628\u0627\u0642\u0629_\u0627\u0644\u0630\u0647\u0628\u064A)
  \u0627\u0631\u062C\u0639 \u0627\u0644\u062C\u062F\u0648\u0644
}

# 4. \u0625\u0639\u062F\u0627\u062F \u0646\u0645\u0648\u0630\u062C \u0627\u0644\u0627\u062A\u0635\u0644 \u0628\u064A \u0623\u0648 \u0627\u0644\u0628\u0631\u064A\u062F \u0627\u0644\u0633\u0631\u064A\u0639
\u062F\u0627\u0644\u0629 \u0646\u0645\u0648\u0630\u062C_\u0628\u0631\u064A\u062F_\u0633\u0631\u064A\u0639(\u0627\u0644\u0635\u0641\u062D\u0629, \u0639\u0646\u0648\u0627\u0646_\u0627\u0644\u0646\u0645\u0648\u0630\u062C, \u0627\u0644\u0628\u0631\u064A\u062F_\u0627\u0644\u0627\u0644\u0643\u062A\u0631\u0648\u0646\u064A) {
  \u0627\u0643\u062A\u0628("\u2728 \u062C\u0627\u0631\u064A \u0625\u062F\u0631\u0627\u062C \u0646\u0645\u0648\u0630\u062C \u062A\u0648\u0627\u0635\u0644 \u0648\u062A\u0623\u0645\u064A\u0646 \u0642\u0646\u0648\u0627\u062A \u0627\u0644\u0627\u062A\u0635\u0627\u0644 \u0645\u0628\u0627\u0634\u0631\u0629...")
  \u0627\u0646\u0634\u0626 \u0627\u0644\u0646\u0645\u0648\u0630\u062C = \u062A\u0635\u0645\u064A\u0645_\u0646\u0645\u0648\u0630\u062C(\u0627\u0644\u0635\u0641\u062D\u0629, \u0639\u0646\u0648\u0627\u0646_\u0627\u0644\u0646\u0645\u0648\u0630\u062C, \u0627\u0644\u0628\u0631\u064A\u062F_\u0627\u0644\u0627\u0644\u0643\u062A\u0631\u0648\u0646\u064A)
  \u0627\u0631\u062C\u0639 \u0627\u0644\u0646\u0645\u0648\u0630\u062C
}

# 5. \u0625\u062F\u0631\u0627\u062C \u0632\u0631 \u0639\u0645\u0644 \u0625\u0631\u0634\u0627\u062F\u064A \u0645\u0639 \u062D\u0632\u0645 \u0627\u0644\u062A\u0623\u062B\u064A\u0631\u0627\u062A \u0627\u0644\u0628\u0635\u0631\u064A\u0629
\u062F\u0627\u0644\u0629 \u0632\u0631_\u062A\u0648\u062C\u064A\u0647_\u0648\u062D\u0641\u0638(\u0627\u0644\u0635\u0641\u062D\u0629, \u0646\u0635_\u0627\u0644\u0632\u0631) {
  \u0627\u0643\u062A\u0628("\u2728 \u062A\u0645 \u0625\u062F\u062E\u0627\u0644 \u0632\u0631 \u062A\u0641\u0627\u0639\u0644\u064A \u0645\u062E\u0635\u0635 \u0639\u0644\u0649 \u0627\u0644\u0635\u0641\u062D\u0629:")
  \u0627\u0646\u0634\u0626 \u0627\u0644\u0632\u0631 = \u0648\u0627\u062C\u0647\u0629_\u0632\u0631(\u0627\u0644\u0635\u0641\u062D\u0629, \u0646\u0635_\u0627\u0644\u0632\u0631)
  \u0627\u0631\u062C\u0639 \u0627\u0644\u0632\u0631
}


# --- \u0645\u0643\u062A\u0628\u0629 \u0642\u064A\u0627\u0633\u064A\u0629: ux_effects.noor ---
# \u0645\u0643\u062A\u0628\u0629 \u0627\u0644\u0645\u064A\u0643\u0631\u0648-\u0625\u0646\u062A\u0631\u0627\u0643\u0634\u0646 \u0648\u0627\u0644\u062A\u0623\u062B\u064A\u0631\u0627\u062A \u0627\u0644\u0628\u0635\u0631\u064A\u0629 \u0648\u0627\u0644\u062D\u0631\u0643\u064A\u0629 (Noor Motion & Micro-Interactions Library)
# \u0647\u0630\u0647 \u0627\u0644\u0645\u0643\u062A\u0628\u0629 \u0645\u062E\u0635\u0635\u0629 \u0644\u0625\u062F\u0627\u0631\u0629 \u0627\u0644\u062D\u0631\u0643\u0627\u062A \u0627\u0644\u0627\u0646\u062A\u0642\u0627\u0644\u064A\u0629 \u0627\u0644\u0633\u0644\u0633\u0629 \u0644\u0635\u0641\u062D\u0627\u062A \u0627\u0644\u0648\u064A\u0628 \u0628\u0645\u062C\u0631\u062F \u0627\u0644\u0645\u0646\u0627\u062F\u0627\u0629.

\u0627\u0643\u062A\u0628("\u{1F3AD} \u062A\u0645 \u062A\u0641\u0639\u064A\u0644 \u0645\u062D\u0631\u0643 \u0627\u0644\u062D\u0631\u0643\u0627\u062A \u0648\u0627\u0644\u0645\u0624\u062B\u0631\u0627\u062A \u0627\u0644\u0628\u0635\u0631\u064A\u0629 \u0627\u0644\u0630\u0643\u064A\u0629 \u0644\u0640 (Noor Motion v5.0).")

# \u062F\u0627\u0644\u0629 \u0644\u062A\u0633\u062C\u064A\u0644 \u0648\u0636\u0628\u0637 \u062D\u0631\u0643\u0629 \u0627\u0644\u062F\u062E\u0648\u0644 \u0627\u0644\u062A\u0641\u0627\u0639\u0644\u064A\u0629 \u0644\u0644\u0639\u0646\u0627\u0635\u0631 \u0648\u0627\u0644\u0634\u0631\u0627\u0626\u062D
\u062F\u0627\u0644\u0629 \u062A\u0641\u0639\u064A\u0644_\u0645\u0624\u062B\u0631_\u0627\u0644\u062F\u062E\u0648\u0644(\u0627\u0644\u0647\u064A\u0643\u0644, \u0646\u0648\u0639_\u0627\u0644\u062A\u0623\u062B\u064A\u0631) {
  \u0627\u0643\u062A\u0628("\u2728 \u062A\u0647\u064A\u0626\u0629 \u062D\u0631\u0643\u0629 \u0627\u0644\u062F\u062E\u0648\u0644 \u0627\u0644\u0628\u0635\u0631\u064A\u0629 \u0627\u0644\u0645\u062A\u0642\u062F\u0645\u0629 \u0645\u0646 \u0627\u0644\u0646\u0648\u0639:", \u0646\u0648\u0639_\u0627\u0644\u062A\u0623\u062B\u064A\u0631)
  \u0627\u0630\u0627 (\u0646\u0648\u0639_\u0627\u0644\u062A\u0623\u062B\u064A\u0631 == "\u062A\u0644\u0627\u0634\u064A") {
    \u0625\u0636\u0627\u0641\u0629_\u062A\u0623\u062B\u064A\u0631_\u062D\u0631\u0643\u0629(\u0627\u0644\u0647\u064A\u0643\u0644, "fade_in_ambient")
  }
  \u0627\u0630\u0627 (\u0646\u0648\u0639_\u0627\u0644\u062A\u0623\u062B\u064A\u0631 == "\u0627\u0631\u062A\u062F\u0627\u062F") {
    \u0625\u0636\u0627\u0641\u0629_\u062A\u0623\u062B\u064A\u0631_\u062D\u0631\u0643\u0629(\u0627\u0644\u0647\u064A\u0643\u0644, "bounce_elegant")
  }
  \u0627\u0630\u0627 (\u0646\u0648\u0639_\u0627\u0644\u062A\u0623\u062B\u064A\u0631 == "\u062A\u0623\u0631\u064A\u0636") {
    \u0625\u0636\u0627\u0641\u0629_\u062A\u0623\u062B\u064A\u0631_\u062D\u0631\u0643\u0629(\u0627\u0644\u0647\u064A\u0643\u0644, "micro_focus")
  }
  \u0627\u0631\u062C\u0639 \u0646\u0639\u0645
}

# \u062F\u0627\u0644\u0629 \u0644\u062A\u0634\u063A\u064A\u0644 \u0648\u0645\u064A\u0636 \u0644\u0648\u0646\u064A \u0639\u0646\u062F \u0627\u0644\u062A\u0641\u0627\u0639\u0644 \u0645\u0639 \u0623\u0632\u0631\u0627\u0631 \u0627\u0644\u0646\u0645\u0627\u0630\u062C
\u062F\u0627\u0644\u0629 \u062A\u0641\u0639\u064A\u0644_\u062A\u0623\u062B\u064A\u0631_\u062A\u0641\u0627\u0639\u0644\u064A(\u0627\u0644\u0632\u0631, \u0627\u0644\u0644\u0648\u0646_\u0627\u0644\u062D\u064A\u0648\u064A) {
  \u0627\u0643\u062A\u0628("\u{1F3AD} \u062A\u0637\u0628\u064A\u0642 \u062A\u0623\u062B\u064A\u0631 \u0627\u0644\u0636\u063A\u0637 \u0627\u0644\u0645\u063A\u0646\u0627\u0637\u064A\u0633\u064A \u0648\u0627\u0644\u062A\u0623\u0631\u064A\u0636 \u0627\u0644\u0628\u0635\u0631\u064A \u0628\u0644\u0648\u0646\u0643 \u0627\u0644\u0641\u0627\u062E\u0631:", \u0627\u0644\u0644\u0648\u0646_\u0627\u0644\u062D\u064A\u0648\u064A)
  # \u0645\u062D\u0627\u0643\u0627\u0629 \u0631\u0628\u0637 \u0627\u0644\u062A\u0641\u0627\u0639\u0644 \u0627\u0644\u0644\u0648\u0646\u064A \u0628\u0645\u062D\u0631\u0643 \u0627\u0644\u0631\u0633\u0645
  \u0627\u0631\u062C\u0639 \u0646\u0639\u0645
}


# --- \u0645\u0643\u062A\u0628\u0629 \u0642\u064A\u0627\u0633\u064A\u0629: web_advanced.noor ---
# \u0645\u0643\u062A\u0628\u0629 \u0627\u0644\u0648\u064A\u0628 \u0627\u0644\u0634\u0627\u0645\u0644\u0629 - Web Master Library
# \u062F\u0627\u0644\u0629 \u0628\u0646\u0627\u0621 \u0645\u0648\u0627\u0642\u0639 \u0645\u062A\u0637\u0648\u0631\u0629 \u062A\u0634\u0645\u0644 \u0646\u0635\u0648\u0635\u060C \u0648\u0633\u0627\u0626\u0637\u060C \u0642\u0648\u0627\u0626\u0645\u060C \u062C\u062F\u0627\u0648\u0644 \u0648\u0646\u0645\u0627\u0630\u062C

\u0627\u0643\u062A\u0628("\u{1F310} \u062A\u062D\u0645\u064A\u0644 \u0645\u0643\u062A\u0628\u0629 \u0645\u0639\u0645\u0627\u0631\u064A\u0629 \u0627\u0644\u0648\u064A\u0628 \u0627\u0644\u0643\u0627\u0645\u0644\u0629...")

\u062F\u0627\u0644\u0629 \u062A\u0635\u0645\u064A\u0645_\u0645\u0648\u0642\u0639_\u0645\u062A\u0643\u0627\u0645\u0644(\u0627\u0633\u0645_\u0627\u0644\u0645\u0648\u0642\u0639) {
  \u0627\u0646\u0634\u0626 \u0645\u0648\u0642\u0639 = \u0647\u064A\u0643\u0644_\u0635\u0641\u062D\u0629(\u0627\u0633\u0645_\u0627\u0644\u0645\u0648\u0642\u0639)
  \u062E\u0644\u0641\u064A\u0629_\u0627\u0644\u0635\u0648\u0631\u0629(\u0645\u0648\u0642\u0639, "\u0623\u0633\u0648\u062F_\u062A\u064A\u062A\u0627\u0646\u064A\u0648\u0645")
  
  # \u0627\u0644\u062A\u062D\u0643\u0645 \u0628\u0627\u0644\u0623\u0628\u0639\u0627\u062F: \u062A\u062D\u062F\u064A\u062F \u0627\u0644\u0637\u0648\u0644\u060C \u0648\u0627\u0644\u0639\u0631\u0636\u060C \u0648\u0627\u0644\u0645\u0633\u0627\u0641\u0627\u062A
  \u0627\u0644\u062A\u062D\u0643\u0645_\u0628\u0627\u0644\u0623\u0628\u0639\u0627\u062F(\u0645\u0648\u0642\u0639, 100, 100, 15)
  
  # \u0625\u0636\u0627\u0641\u0629 \u0627\u0644\u0646\u0635\u0648\u0635 \u0648\u0627\u0644\u0639\u0646\u0627\u0648\u064A\u0646
  \u0625\u0636\u0627\u0641\u0629_\u0646\u0635\u0648\u0635(\u0645\u0648\u0642\u0639, "\u0627\u0644\u0639\u0646\u0648\u0627\u0646_\u0627\u0644\u0631\u0626\u064A\u0633\u064A", "\u0645\u0631\u062D\u0628\u0627\u064B \u0628\u0643\u0645 \u0641\u064A \u0639\u0627\u0644\u0645 \u0644\u063A\u0629 \u0646\u0648\u0631")
  \u062A\u0644\u0648\u064A\u0646_\u0627\u0644\u0646\u0635(\u0645\u0648\u0642\u0639, "\u0623\u0628\u064A\u0636")
  \u062A\u0646\u0633\u064A\u0642_\u0627\u0644\u062E\u0637(\u0645\u0648\u0642\u0639, "Cairo", 32, "\u0639\u0631\u064A\u0636_\u062C\u062F\u0627\u064B")
  
  # \u0625\u062F\u0631\u0627\u062C \u0627\u0644\u0648\u0633\u0627\u0626\u0637 (\u0635\u0648\u0631 \u0648\u0641\u064A\u062F\u064A\u0648 \u0648\u0635\u0648\u062A)
  \u0625\u062F\u0631\u0627\u062C_\u0648\u0633\u0627\u0626\u0637(\u0645\u0648\u0642\u0639, "\u0635\u0648\u0631\u0629", "assets/hero_image.png")
  \u0625\u062F\u0631\u0627\u062C_\u0648\u0633\u0627\u0626\u0637(\u0645\u0648\u0642\u0639, "\u0641\u064A\u062F\u064A\u0648", "assets/promo.mp4")
  
  # \u0625\u0636\u0627\u0641\u0629 \u0627\u0644\u0642\u0648\u0627\u0626\u0645 \u0648\u0627\u0644\u0631\u0648\u0627\u0628\u0637
  \u0627\u0646\u0634\u0626 \u0642\u0627\u0626\u0645\u0629_\u0627\u0644\u062A\u0646\u0642\u0644 = \u0628\u0646\u0627\u0621_\u0642\u0627\u0626\u0645\u0629("\u0645\u0631\u0642\u0645\u0629", ["\u0627\u0644\u0631\u0626\u064A\u0633\u064A\u0629", "\u0627\u0644\u062E\u062F\u0645\u0627\u062A", "\u0627\u0644\u0645\u0634\u0627\u0631\u064A\u0639", "\u0627\u062A\u0635\u0644 \u0628\u0646\u0627"])
  \u062A\u0648\u062C\u064A\u0647_\u0631\u0627\u0628\u0637(\u0645\u0648\u0642\u0639, "https://noor.lang.org")
  
  # \u0635\u0646\u0639 \u0627\u0644\u0646\u0645\u0627\u0630\u062C \u0648\u062A\u0635\u0645\u064A\u0645 \u0627\u0644\u062C\u062F\u0627\u0648\u0644
  \u0627\u0646\u0634\u0626 \u0627\u062A\u0635\u0644_\u0628\u0646\u0627 = \u062A\u0635\u0645\u064A\u0645_\u0646\u0645\u0648\u0630\u062C("\u062A\u0648\u0627\u0635\u0644 \u0645\u0639\u0646\u0627", "\u0627\u0644\u0627\u064A\u0645\u064A\u0644_\u0627\u0644\u0645\u062F\u062E\u0644")
  \u0627\u0646\u0634\u0626 \u062C\u062F\u0648\u0644 = \u062A\u0635\u0645\u064A\u0645_\u062C\u062F\u0648\u0644(["\u062E\u062F\u0645\u0629", "\u0633\u0639\u0631"])
  \u0627\u0636\u0641_\u0635\u0641_\u062C\u062F\u0648\u0644(\u062C\u062F\u0648\u0644, ["\u062A\u0635\u0645\u064A\u0645 \u0645\u062A\u062C\u0627\u0648\u0628", "\u0645\u062C\u0627\u0646\u064A"])
  
  # \u062A\u062C\u0627\u0648\u0628 \u0648\u062A\u0648\u062C\u064A\u0647 \u0645\u062A\u0635\u0641\u062D\u0627\u062A
  \u062A\u0631\u062A\u064A\u0628_\u0639\u0646\u0627\u0635\u0631(\u0645\u0648\u0642\u0639, "\u062A\u0644\u0642\u0627\u0626\u064A_\u0645\u062A\u062C\u0627\u0648\u0628")
  \u062A\u062C\u0627\u0648\u0628_\u0627\u0644\u0648\u0627\u062C\u0647\u0629(\u0645\u0648\u0642\u0639, ["\u0647\u0627\u062A\u0641", "\u0634\u0627\u0634\u0629_\u0639\u0645\u0644\u0627\u0642\u0629", "\u062A\u0644\u0641\u0627\u0632"])
  \u062A\u0648\u062C\u064A\u0647_\u0645\u062A\u0635\u0641\u062D("\u0643\u0631\u0648\u0645_\u0648\u0633\u064E\u0641\u0627\u0631\u064A", \u0645\u0648\u0642\u0639)
  
  \u0627\u0631\u062C\u0639 \u0645\u0648\u0642\u0639
}


# --- \u0645\u0643\u062A\u0628\u0629 \u0642\u064A\u0627\u0633\u064A\u0629: web_dom.noor ---
# \u0645\u0643\u062A\u0628\u0629 \u0627\u0644\u0648\u064A\u0628 \u0648\u062A\u0635\u0645\u064A\u0645 \u0648\u0627\u062C\u0647\u0627\u062A \u0627\u0644\u0645\u0633\u062A\u062E\u062F\u0645 (Web DOM & UI Library)
# \u0645\u0643\u062A\u0628\u0629 \u0635\u0645\u0645\u062A \u062E\u0635\u064A\u0635\u0627\u064B \u0641\u064A \u0644\u063A\u0629 \u0646\u0648\u0631 \u0644\u0628\u0646\u0627\u0621 \u0645\u0646\u0635\u0627\u062A \u0648\u0645\u0648\u0627\u0642\u0639 \u0627\u062D\u062A\u0631\u0627\u0641\u064A\u0629\u060C \u0645\u062A\u062C\u0627\u0648\u0628\u0629\u060C \u0648\u0633\u0631\u064A\u0639\u0629

\u0627\u0643\u062A\u0628("\u{1F310} \u062A\u0645 \u0627\u0633\u062A\u062F\u0639\u0627\u0621 \u0627\u0644\u0645\u0643\u062A\u0628\u0629 \u0627\u0644\u0642\u064A\u0627\u0633\u064A\u0629 \u0627\u0644\u0645\u0641\u062A\u0648\u062D\u0629 \u0644\u0644\u0648\u064A\u0628 \u0648\u0627\u0644\u0645\u0646\u0635\u0627\u062A \u0627\u0644\u062A\u0641\u0627\u0639\u0644\u064A\u0629 (Web DOM V5.0)")

# 1. \u062A\u0647\u064A\u0626\u0629 \u0627\u0644\u0635\u0641\u062D\u0629 \u0648\u0627\u0644\u062C\u0630\u0648\u0631 \u0627\u0644\u0623\u0633\u0627\u0633\u064A\u0629
\u062F\u0627\u0644\u0629 \u0628\u0646\u0627\u0621_\u0635\u0641\u062D\u0629_\u062F\u064A\u0646\u0627\u0645\u064A\u0643\u064A\u0629(\u0639\u0646\u0648\u0627\u0646_\u0627\u0644\u0635\u0641\u062D\u0629) {
  \u0627\u0643\u062A\u0628("-> \u062C\u0627\u0631\u064A \u062A\u0623\u0633\u064A\u0633 \u0628\u0646\u064A\u0629 \u0627\u0644\u0640 DOM \u0644\u0644\u0645\u0633\u062A\u0646\u062F:", \u0639\u0646\u0648\u0627\u0646_\u0627\u0644\u0635\u0641\u062D\u0629)
  \u0627\u0646\u0634\u0626 \u0627\u0644\u0647\u064A\u0643\u0644 = \u0647\u064A\u0643\u0644_\u0635\u0641\u062D\u0629(\u0639\u0646\u0648\u0627\u0646_\u0627\u0644\u0635\u0641\u062D\u0629)
  \u062E\u0644\u0641\u064A\u0629_\u0627\u0644\u0635\u0648\u0631\u0629(\u0627\u0644\u0647\u064A\u0643\u0644, "\u0623\u0633\u0648\u062F_\u0639\u0645\u064A\u0642")
  \u062A\u0644\u0648\u064A\u0646_\u0627\u0644\u0646\u0635(\u0627\u0644\u0647\u064A\u0643\u0644, "\u0623\u0628\u064A\u0636_\u0641\u0636\u064A")
  \u062A\u0646\u0633\u064A\u0642_\u0627\u0644\u062E\u0637(\u0627\u0644\u0647\u064A\u0643\u0644, "Tajawal", 20, "\u0639\u0627\u062F\u064A")
  \u0627\u0631\u062C\u0639 \u0627\u0644\u0647\u064A\u0643\u0644
}

# 2. \u0625\u0646\u0634\u0627\u0621 \u0646\u0645\u0648\u0630\u062C \u062A\u0633\u062C\u064A\u0644 \u0627\u0644\u062F\u062E\u0648\u0644 \u0627\u0644\u0634\u0627\u0626\u0639
\u062F\u0627\u0644\u0629 \u062A\u0635\u0645\u064A\u0645_\u0646\u0627\u0641\u0630\u0629_\u062A\u0633\u062C\u064A\u0644(\u0639\u0646\u0648\u0627\u0646_\u0627\u0644\u0646\u0627\u0641\u0630\u0629) {
  \u0627\u0643\u062A\u0628("-> \u062A\u0635\u0645\u064A\u0645 \u0646\u0645\u0648\u0630\u062C \u0645\u062A\u0641\u0627\u0639\u0644 \u062C\u062F\u064A\u062F \u0644\u0640:", \u0639\u0646\u0648\u0627\u0646_\u0627\u0644\u0646\u0627\u0641\u0630\u0629)
  \u0627\u0646\u0634\u0626 \u0627\u0644\u0646\u0645\u0648\u0630\u062C = \u062A\u0635\u0645\u064A\u0645_\u0646\u0645\u0648\u0630\u062C(\u0639\u0646\u0648\u0627\u0646_\u0627\u0644\u0646\u0627\u0641\u0630\u0629, "user@example.com")
  \u062A\u0631\u062A\u064A\u0628_\u0639\u0646\u0627\u0635\u0631(\u0627\u0644\u0646\u0645\u0648\u0630\u062C, "\u0645\u0646\u062A\u0635\u0641_\u0627\u0644\u0634\u0627\u0634\u0629")
  \u062A\u062C\u0627\u0648\u0628_\u0627\u0644\u0648\u0627\u062C\u0647\u0629(\u0627\u0644\u0646\u0645\u0648\u0630\u062C, ["\u0643\u0645\u0628\u064A\u0648\u062A\u0631", "\u0647\u0627\u062A\u0641", "\u0644\u0648\u062D\u064A"])
  \u0625\u0636\u0627\u0641\u0629_\u062A\u0623\u062B\u064A\u0631_\u062D\u0631\u0643\u0629(\u0627\u0644\u0646\u0645\u0648\u0630\u062C, "\u062A\u0644\u0627\u0634\u064A_\u062F\u062E\u0648\u0644_\u0628\u0637\u064A\u0621")
  
  \u0627\u0646\u0634\u0626 \u062E\u064A\u0627\u0631_\u0627\u0644\u0632\u0631 = \u0648\u0627\u062C\u0647\u0629_\u0632\u0631("\u062A\u0623\u0643\u064A\u062F \u0648\u062D\u0641\u0638")
  \u0627\u0643\u062A\u0628("   [\u062A\u0645 \u0625\u062F\u0631\u0627\u062C \u0632\u0631 \u0641\u064A \u0627\u0644\u0646\u0627\u0641\u0630\u0629 \u0627\u0644\u062A\u0641\u0627\u0639\u0644\u064A\u0629]")
  
  \u0627\u0631\u062C\u0639 \u0627\u0644\u0646\u0645\u0648\u0630\u062C
}

# 3. \u0628\u0646\u0627\u0621 \u0644\u0648\u062D\u0629 \u0627\u0644\u062A\u062D\u0643\u0645 \u0627\u0644\u0645\u062E\u0635\u0635\u0629 \u0644\u0644\u0645\u0637\u0648\u0631\u064A\u0646
\u062F\u0627\u0644\u0629 \u0628\u0646\u0627\u0621_\u0644\u0648\u062D\u0629_\u062A\u062D\u0643\u0645(\u0627\u0644\u0639\u0646\u0627\u0648\u064A\u0646, \u0627\u0644\u0628\u064A\u0627\u0646\u0627\u062A_\u0627\u0644\u0627\u0641\u062A\u0631\u0627\u0636\u064A\u0629) {
  \u0627\u0643\u062A\u0628("-> \u062A\u0647\u064A\u0626\u0629 \u062C\u062F\u0648\u0644 \u0644\u0648\u062D\u0629 \u0627\u0644\u062A\u062D\u0643\u0645 \u0627\u0644\u0625\u062F\u0627\u0631\u064A\u0629...")
  \u0627\u0646\u0634\u0626 \u0627\u0644\u062C\u062F\u0648\u0644 = \u062A\u0635\u0645\u064A\u0645_\u062C\u062F\u0648\u0644(\u0627\u0644\u0639\u0646\u0627\u0648\u064A\u0646)
  
  \u0637\u0627\u0644\u0645\u0627 (\u062D\u062C\u0645(\u0627\u0644\u0628\u064A\u0627\u0646\u0627\u062A_\u0627\u0644\u0627\u0641\u062A\u0631\u0627\u0636\u064A\u0629) > 0) {
    \u0627\u0646\u0634\u0626 \u0635\u0641 = \u0627\u0644\u0628\u064A\u0627\u0646\u0627\u062A_\u0627\u0644\u0627\u0641\u062A\u0631\u0627\u0636\u064A\u0629[0]
    \u0627\u0636\u0641_\u0635\u0641_\u062C\u062F\u0648\u0644(\u0627\u0644\u062C\u062F\u0648\u0644, \u0635\u0641)
    \u0627\u0643\u062A\u0628("   [\u062A\u0645 \u0625\u062F\u0631\u0627\u062C \u0635\u0641 \u0628\u064A\u0627\u0646\u0627\u062A]")
    \u0627\u0644\u0628\u064A\u0627\u0646\u0627\u062A_\u0627\u0644\u0627\u0641\u062A\u0631\u0627\u0636\u064A\u0629 = [] 
  }
  
  \u0627\u0631\u062C\u0639 \u0627\u0644\u062C\u062F\u0648\u0644
}

