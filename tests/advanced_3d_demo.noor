# تجربة محرك ألعاب نور السيادي المتطور ثلاثي الأبعاد
اكتب("=======================================")
اكتب("🎮 تهيئة المشهد الفاخر ثلاثي الأبعاد بمحرك نور السيادي...")
اكتب("=======================================")

# 1. إعداد عالم اللعبة مع الضباب والجاذبية الكونيه والاسم
إعداد_عالم_3D({
  "GameName": "سباق نور السيادي الفاخر",
  "gravity": -9.81,
  "ضباب": صحيح,
  "إضاءة_محيطية": 0.2
})

# 2. إعداد الكاميرات المتقدمة (كاميرا تتبع تتبع البطل)
إنشاء_كاميرا({
  "نوع_الكاميرا": "follow", 
  "س": 0, "ص": 10, "ع": -25,
  "مسافة": 18,
  "ارتفاع": 6,
  "زاوية": 180
})

# 3. إعداد إضاءات المشهد المتعددة (إضاءة موجهة للشمس وإضاءة منقطة متوهجة)
إنشاء_إضاءة({
  "نوع": "directional",
  "س": -10, "ص": 30, "ع": -10,
  "اتجاه_س": 0.5, "اتجاه_ص": -1.0, "اتجاه_ع": 0.5,
  "قوة": 0.8,
  "لون": "#ffffff"
})

إنشاء_إضاءة({
  "نوع": "point",
  "س": 5, "ص": 6, "ع": 5,
  "قوة": 1.5,
  "لون": "برتقالي"
})

# 4. بناء أرضية الملعب مع خامة عشبية متقدمة
إنشاء_مجسم({
  "نوع": "أرضية",
  "س": 0, "ص": 0, "ع": 0,
  "العرض": 150,
  "الطول": 150,
  "لون": "عشب",
  "كتلة": 0
})

# 5. زرع مباني وعقبات في البيئة
إنشاء_مجسم({
  "نوع": "مبنى",
  "اسم": "ناطحة_سحاب",
  "س": -20, "ص": 10, "ع": 25,
  "العرض": 6, "الارتفاع": 20, "الطول": 6,
  "لون": "طوب"
})

إنشاء_مجسم({
  "نوع": "مبنى",
  "اسم": "برج_شبه_معدني",
  "س": 20, "ص": 8, "ع": 20,
  "العرض": 5, "الارتفاع": 16, "الطول": 5,
  "لون": "حديد"
})

# 6. إضافة كرات فيزيائية متساقطة مصنوعة من الذهب الخالص لتجربة خامة الانعكاس والارتداد
إنشاء_مجسم({
  "نوع": "كرة",
  "اسم": "الكرة_الذهبية",
  "س": 0, "ص": 25, "ع": 5,
  "القطر": 3.0,
  "كتلة": 3,
  "مرونة": 0.65,
  "لون": "ذهب"
})

# 7. إضافة نظام جزيئات متوهجة (مثل لهب أو دخان) في الفضاء
إنشاء_مجسم({
  "نوع": "جزيئات",
  "اسم": "البركان_المتوهج",
  "س": 5, "ص": 1.5, "ع": 5,
  "لون": "برتقالي",
  "حجم_أصغر": 0.15,
  "حجم_أكبر": 0.6,
  "عمر_أصغر": 0.5,
  "عمر_أكبر": 1.5,
  "تعداد": 200,
  "جاذبية_جزيئات": 2.5
})

# 8. إضافة مركبة سيارة يتحكم بها اللاعب (سيسير اللاعب بالمركبة ويمارس التفحيط في المشهد!)
إنشاء_مجسم({
  "نوع": "سيارة",
  "اسم": "لاعب_المركبة_الرياضية",
  "س": 0, "ص": 3, "ع": -5,
  "العرض": 2, "الارتفاع": 1, "الطول": 3.5,
  "كتلة": 2.0,
  "احتكاك": 0.1,
  "لون": "أحمر"
})

اكتب("🏎️ تم تصميم عالم السباق بنجاح! شغل اللعبة لمشاهدة الانعكاسات الذهبية، الدخان المتوهج، وحركة السيارة بالتفحيط!")
