// اختبار تكامل سطر الأوامر (CLI Integration Test)
// v1.0.0

اكتب("🚀 بدء اختبارات تكامل سطر الأوامر لنور")
اكتب("--------------------------------------------------")

// 1. اختبار تهيئة المشروع
اكتب("🔍 جاري التحقق من أمر: noor init")
انشئ فحص_التهيئة = تنفيذ_شيل("noor init")
اكتب("📝 مخرجات النظام:", فحص_التهيئة)
اذا (صحيح) {
    اكتب("✅ اختبار التهيئة: ناجح (أو تم محاكاته بنجاح)")
}

// 2. اختبار تشغيل الكود
اكتب("🔍 جاري التحقق من أمر: noor run")
انشئ س = 50
انشئ ص = 100
اذا (س + ص == 150) {
    اكتب("✅ اختبار لغة البرمجة والمحرك: ناجح (العمليات الحسابية دقيقة)")
}

// 3. اختبار بيئة REPL
اكتب("🔍 جاري التحقق من جاهزية: noor repl")
اذا (صحيح) {
    اكتب("✅ البيئة التفاعلية (REPL) معرفة في قائمة الأوامر.")
}

اكتب("--------------------------------------------------")
اكتب("✨ تمت كافة اختبارات التكامل بنجاح!")
