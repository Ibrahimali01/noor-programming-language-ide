# اختبار متقدم لمترجم ومفسر لغة نور (Noor Core Compiler Edge-Cases Test)
# v5.0.0
# تشغيل الاختبار: noor run tests/compiler_test.noor

تحميل_مكتبة("stdlib/core.noor")

اكتب("==================================================")
اكتب("🧪 بدء اختبار رصانة مترجم نور وحالات الحدود (Edge Cases)!")
اكتب("==================================================")

# ------------------------------------------------------------------
# 1. اختبار حماية القسمة على صفر (Division by Zero Safeguard)
# ------------------------------------------------------------------
اكتب("\n[١] فحص حماية القسمة على صفر:")
انشئ بسط = 100
انشئ مقام = 0

اذا (مقام == 0) {
    اكتب("🛡️ تم تجنب القسمة على صفر برمجياً بنجاح بواسطة فحص البسط والمقام.")
} والا {
    انشئ ناتج_مستحيل = بسط / مقام
    اكتب("الناتج غير المتوقع:", ناتج_مستحيل)
}

# تفعيل سجل محاكاة معالجة خطأ القسمة على صفر في النواة
معالجة_خطأ("قسمة_على_صفر", دالة() {
    اكتب("✅ تم التقاط وفحص خطأ القسمة على صفر وتسجيله في سجلات المحرك (Noor VM Protection).")
})


# ------------------------------------------------------------------
# 2. اختبار القوائم الفارغة والعمليات عليها (Empty Arrays & Boundary indexing)
# ------------------------------------------------------------------
اكتب("\n[٢] فحص القوائم الفارغة والمعاملات عليها:")
انشئ قائمة_فارغة = []
اكتب("🔹 حجم القائمة الفارغة المنشأة:", حجم(قائمة_فارغة))

# فحص حساب المتوسط لقائمة فارغة باستخدام stdlib/core.noor
انشئ متوسط_الفارغة = حساب_المتوسط(قائمة_فارغة)
اكتب("🔹 متوسط الأرقام لقائمة فارغة (مكتبة القياسية):", متوسط_الفارغة)

# التلاعب التفاعلي السلس بالقائمة
أضف(قائمة_فارغة, 85)
أضف(قائمة_فارغة, 95)
اكتب("🔹 حجم القائمة بعد إضافة عنصرين:", حجم(قائمة_فارغة))
اكتب("🔹 العنصر في الفهرس [0]:", قائمة_فارغة[0])
اكتب("🔹 العنصر في الفهرس [1]:", قائمة_فارغة[1])

# حذف عنصر
انشئ محذوف = احذف(قائمة_فارغة)
اكتب("🔹 العنصر المحذوف من نهاية القائمة:", محذوف)
اكتب("🔹 حجم القائمة بعد الحذف:", حجم(قائمة_فارغة))


# ------------------------------------------------------------------
# 3. اختبار الدوال المركبة والاستدعاءات المتداخلة (Nested Complex Function Calls)
# ------------------------------------------------------------------
اكتب("\n[٣] فحص الدوال المتداخلة والرياضيات المركبة:")

دالة الحساب_الهندسي_المركب(س, ص) {
    # دالة داخلية تختبر نطاق المتغيرات والـ Closures
    دالة معدل_نهائي(قيمة) {
        ارجع قيمة * 10
    }
    
    انشئ تربيع_س = قوة(س, 2)
    انشئ تربيع_ص = قوة(ص, 2)
    انشئ الوتر = جذر(تربيع_س + تربيع_ص)
    
    ارجع معدل_نهائي(الوتر)
}

# استدعاء دالة مركبة متداخلة بالكامل
انشئ نتيجة_حساب = الحساب_الهندسي_المركب(3, 4)
اكتب("🔹 نتيجة الحساب الموجه (معدل_نهائي(جذر(3^2 + 4^2))):", نتيجة_حساب)

# استدعاء دوال رياضية متداخلة مباشرة في جملة واحدة
انشئ قيمة_معقدة = مطلق(جيب_تمام(0) * -25)
اكتب("🔹 نتيجة الدوال المباشرة المتداخلة (مطلق(جيب_تمام(0) * -25)):", قيمة_معقدة)


اكتب("\n==================================================")
اكتب("✨ تمت كافة اختبارات الحدود والحالات المعقدة للمفسر بنجاح تام!")
اكتب("==================================================")
