// ملف اختبار نظام الفيزياء بلغة ومحرك نور السيادية (PhysicsSystem Standard Test Suite)
تحميل_مكتبة("game_engine")

اكتب("=========================================================")
اكتب("🧪 بدء اختبار وحدة معالجة الفيزياء وحساب التصادمات المتقدمة 🧪")
اكتب("=========================================================")

# 1. تهيئة الأجسام الفيزيائية مع كتلة (mass) وأبعاد صندوقية
# الكائن الأول سيعامل كلاعب، والثاني كعقبة أو جدار
انشئ كائن_أ = {نوع: "player", اسم: "الصاروخ_الخفيف", س: 0, ص: 0, عرض: 10, ارتفاع: 10, سرعة_س: 20, سرعة_ص: 0, كتلة: 1.0}
انشئ كائن_ب = {نوع: "obstacle", اسم: "الجدار_الثقيل", س: 5, ص: 0, عرض: 10, ارتفاع: 10, سرعة_س: 0, سرعة_ص: 0, كتلة: 5.0}

# تجربة تخصيص خامات المواد (Physics Materials)
# سيتم تغيير الجدار ليصبح "صخرة ثقيلة" والصاروخ "مطاطي"
كائن_أ = setPhysicsMaterial(كائن_أ, "bouncy")
كائن_ب = setPhysicsMaterial(كائن_ب, "heavy_stone")

اكتب("📥 الكيانات مجهزة بالكامل:")
اكتب("الكائن أ:", كائن_أ["اسم"], "| الكتلة =", كائن_أ["كتلة"])
اكتب("الكائن ب:", كائن_ب["اسم"], "| الكتلة =", كائن_ب["كتلة"])

# 2. فحص التصادم مع استدعاء دالة حدث التصادم الأوتوماتيكي (onCollision Callback)
دالة معالج_الاصطدام_الديناميكي(ج1, ج2) {
  اكتب("🔔 [بث الحدث] دالة حدث onCollision اشتغلت!")
  اكتب("🔔 تلامس شديد بين:", ج1["اسم"], "و", ج2["اسم"])
}

اكتب("\n[الفحص الأول] اختبار فحص التصادم مع callback (onCollision):")
انشئ هل_تصادما = فحص_تصادم_صندوقي_كامل_مع_استدعاء(كائن_أ, كائن_ب, معالج_الاصطدام_الديناميكي)

# 3. محاكاة تأثير الكتلة على السقوط الحر والجاذبية (Mass Affects Gravity)
اكتب("\n[الفحص الثاني] السقوط المعجل القائم على الكتلة:")
انشئ وقت_تفاضلي = 0.5
انشئ جاذبية = 10.0

انشئ سرعة_قبل_أ = كائن_أ["سرعة_ص"]
انشئ سرعة_قبل_ب = كائن_ب["سرعة_ص"]

كائن_أ = تطبيق_الجاذبية_الكونية(كائن_أ, جاذبية, وقت_تفاضلي)
كائن_ب = تطبيق_الجاذبية_الكونية(كائن_ب, جاذبية, وقت_تفاضلي)

اكتب("سرعة ص للصاروخ الخفيف (كتلة 1) بعد الجاذبية:", كائن_أ["سرعة_ص"])
اكتب("سرعة ص للجدار الثقيل (كتلة 5) بعد الجاذبية:", كائن_ب["سرعة_ص"])

اذا (كائن_ب["سرعة_ص"] > كائن_أ["سرعة_ص"]) {
  اكتب("✅ نجح تفاضل الجاذبية! الجسم الأثقل يسقط أسرع كما هو مطلوب تكتيكياً!")
}

# 4. ردة وفعل الاصطدام التبادلي للكتل (Collision Force Interaction)
اكتب("\n[الفحص الثالث] محاكاة تفاعلات قوة الاصطدام بناء على الكتل:")
كائن_أ["سرعة_س"] = 30.0
كائن_ب["سرعة_س"] = 0.0

انشئ نتائج = solveCollisionWithMass(كائن_أ, كائن_ب)
انشئ كائن_أ_معدل = نتائج[0]
انشئ كائن_ب_معدل = نتائج[1]

اكتب("سرعة س للصاروخ الخفيف بعد ارتداد الصدمة:", كائن_أ_معدل["سرعة_س"])
اكتب("سرعة س للجدار الثقيل بعد ارتداد الصدمة:", كائن_ب_معدل["سرعة_س"])

# 5. اختبار المقاومة والاحتكاك السطحي (Friction & Damping)
اكتب("\n[الفحص الرابع] تطبيق مقاومة الرياح والاحتكاك:")
انشئ معامل_احتكاك = 0.2

كائن_أ_معدل["سرعة_س"] = 100.0
كائن_ب_معدل["سرعة_س"] = 100.0

كائن_أ_معدل = تطبيق_الاحتكاك(كائن_أ_معدل, معامل_احتكاك, وقت_تفاضلي)
كائن_ب_معدل = تطبيق_الاحتكاك(كائن_ب_معدل, معامل_احتكاك, وقت_تفاضلي)

اكتب("سرعة س للصاروخ الخفيف (كتلة 1) بعد الاحتكاك:", كائن_أ_معدل["سرعة_س"])
اكتب("سرعة س للجدار الثقيل (كتلة 5) بعد الاحتكاك:", كائن_ب_معدل["سرعة_س"])

اذا (كائن_ب_معدل["سرعة_س"] > كائن_أ_معدل["سرعة_س"]) {
  اكتب("✅ نجح الفحص الحركي! الجسم الأثقل يملك قدرة قصور ذاتي أكبر ويقاوم الاحتكاك بأداء أعلى!")
}

# 6. اختبار رسم وعرض مخطط الصناديق لتصحيح الأخطاء (debugDrawPhysics visualization)
# ميزة رائعة للمطور لرؤية الصناديق المحيطة عبر وحدة التحكم (Console) والطبقة الرسومية (Overlay)
اكتب("\n[الفحص الخامس] اختبار ميزة تصحيح الأخطاء ورسم محيط الأبعاد:")
debugDrawPhysics(كائن_أ)
رسم_محيط_الفيزياء_لتصحيح_الأخطاء(كائن_ب)
renderPhysicsOverlay(كائن_أ)

# عرض متجهات القوى (Forces Vectors)
اكتب("\n[الفحص الإضافي] عرض متجهات القوة (Force Vectors) للكائنات:")
debugDrawForces(كائن_أ)
debugDrawForces(كائن_ب)

# 7. اختبار الأداء والضغط العالي (Stress Test) لأعداد كبيرة من الأجسام
اكتب("\n[الفحص السادس] اختبار الإجهاد: معالجة 20 جسماً فيزيائياً لـ 10 إطار (Frames):")
انشئ قائمة_الجزيئات = []
انشئ شمار = 0
طالما (شمار < 20) {
  انشئ كتلة_عشوائية = عشوائي(10) + 1
  انشئ الجسيم = {اسم: "جسيم_" + تحويل_لنص(شمار), س: شمار * 10, ص: 0, عرض: 5, ارتفاع: 5, سرعة_س: 5, سرعة_ص: 0, كتلة: كتلة_عشوائية}
  قائمة_الجزيئات = أضف(قائمة_الجزيئات, الجسيم)
  شمار = شمار + 1
}

# محاكاة 10 إطار للسقوط الحر لجميع الأجسام الـ 20
انشئ اطار = 0
طالما (اطار < 10) {
  انشئ i = 0
  طالما (i < 20) {
    انشئ جيم_حالي = قائمة_الجزيئات[i]
    جيم_حالي = تطبيق_الجاذبية_الكونية(جيم_حالي, 9.8, 0.1) # الجاذبية مع 0.1 ثانية كإطار
    جيم_حالي = تحديث_حركة_السرعة(جيم_حالي, 0.1)
    قائمة_الجزيئات[i] = جيم_حالي
    i = i + 1
  }
  اطار = اطار + 1
}

اكتب("تمت معالجة نظام الجزيئات بنجاح. سرعة ص وارتفاع أول وخمس جسيم بعد السقوط:")
اكتب("الجسيم 0 (كتلة", قائمة_الجزيئات[0]["كتلة"], "): الموضع الصادي =", قائمة_الجزيئات[0]["ص"])
اكتب("الجسيم 5 (كتلة", قائمة_الجزيئات[5]["كتلة"], "): الموضع الصادي =", قائمة_الجزيئات[5]["ص"])
اكتب("✅ نجح اختبار الإجهاد العالي للمحرك! حسابات الكتل والتسارع تمت بدقة واحترافية.")

اكتب("\n=========================================================")
اكتب("🎉 انتهت جميع اختبارات نظام الفيزياء المتقدمة والمشفرة بالكامل 🎉")
اكتب("=========================================================")
