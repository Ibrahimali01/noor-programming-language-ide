  \u0627\u0646\u0634\u0626 \u0646\u0647\u0627\u064A\u0629 = \u0645\u0624\u0642\u062A_\u0645\u0644\u064A()
  
  \u0627\u0646\u0634\u0626 \u0627\u0644\u0632\u0645\u0646 = \u0646\u0647\u0627\u064A\u0629 - \u0628\u062F\u0627\u064A\u0629
