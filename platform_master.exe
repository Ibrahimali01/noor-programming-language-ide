  \u0637\u0627\u0644\u0645\u0627 (\u0627\u0644\u0639\u062F\u0627\u062F < \u0627\u0644\u0643\u0644\u064A) {
    \u0627\u0644\u0645\u062C\u0645\u0648\u0639 = \u0627\u0644\u0645\u062C\u0645\u0648\u0639 + \u0642\u0627\u0626\u0645\u0629_\u0623\u0631\u0642\u0627\u0645[\u0627\u0644\u0639\u062F\u0627\u062F]
    \u0627\u0644\u0639\u062F\u0627\u062F = \u0627\u0644\u0639\u062F\u0627\u062F + 1
  }

  \u0627\u0630\u0627 (\u0627\u0644\u0643\u0644\u064A == 0) {
    \u0627\u0631\u062C\u0639 0
  }
  \u0627\u0631\u062C\u0639 \u0627\u0644\u0645\u062C\u0645\u0648\u0639 / \u0627\u0644\u0643\u0644\u064A
